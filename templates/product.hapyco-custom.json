    "faq": {
      "type": "hapyco-faq",
      "blocks": {
        "q1": { "type": "qa", "settings": { "question": "How does the personalization work?", "answer": "<p>It's simple. Choose your size, select your shirt style, and upload a clear photo of your pet. Our team will then turn your pet's photo into a unique design printed directly onto the shirt.</p>" } },
        "q2": { "type": "qa", "settings": { "question": "Can I use any pet?", "answer": "<p>Yes. You can use a dog, cat, rabbit, or any other pet. As long as the photo is clear enough, we can use it.</p>" } },
        "q3": { "type": "qa", "settings": { "question": "What kind of photo should I upload?", "answer": "<p>For the best result, upload a photo where your pet's face is clearly visible, well-lit, and not covered by objects. A front-facing photo usually works best.</p>" } },
        "q4": { "type": "qa", "settings": { "question": "Will the background of my photo be kept?", "answer": "<p>No. We usually remove the background and keep only your pet, so it blends naturally into the tropical shirt design.</p>" } },
        "q5": { "type": "qa", "settings": { "question": "Can I add more than one pet?", "answer": "<p>Yes, you can add multiple pets. We'll adjust the design so each pet is clearly visible and nicely placed on the shirt.</p>" } },
        "q6": { "type": "qa", "settings": { "question": "Will the shirt really look like my pet?", "answer": "<p>Yes. The design is created from the photo you upload. The clearer the photo, the more accurate and detailed the final result will be.</p>" } },
        "q7": { "type": "qa", "settings": { "question": "Does the print last after washing?", "answer": "<p>Yes, the print is made to last. To keep the colors looking fresh, we recommend washing the shirt inside out in cold water and avoiding high-heat drying.</p>" } },
        "q8": { "type": "qa", "settings": { "question": "How do I choose the right size?", "answer": "<p>Please check the size guide before ordering. If you prefer a relaxed or oversized fit, we recommend choosing one size up.</p>" } },
        "q9": { "type": "qa", "settings": { "question": "Is this a good gift idea?", "answer": "<p>Yes, it's a very personal and fun gift for birthdays, Father's Day, Christmas, vacations, or anyone who loves their pet.</p>" } }
