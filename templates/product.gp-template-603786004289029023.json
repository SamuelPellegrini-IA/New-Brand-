        "ggoQB6YO3wQ_text": "<p>Works for A-DD+ cups. Designed specifically for mature bodies needing real support.</p>",
        "ggvyreBNINt_text": "<p><span style=\"font-size:12px;\">Still have questions ? Check here</span></p>",
        "ggwKdXOJiMm_text": "<p><span style=\"color:#232E3E;\"><strong>free returns</strong></span><strong>,</strong> NO QUESTIONS ASKED&nbsp;</p>",
        "ggykT7DQPkE_text": "<p><span style=\"color:#232E3E;\"><strong>45-day</strong></span> money&nbsp;<br>back guarantee</p>"
