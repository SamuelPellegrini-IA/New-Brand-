        "ggYV7eMZQTu_childItem_0": "<p><strong>HAPYCO</strong> is trusted by over <span style=\"color:#00237E;\"><strong>125k+ Men</strong></span> </p>",
        "ggGa-pVtlF0_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0825/9813/4039/files/gempages_491320059759690869-7310a9ae-31ae-41db-92f8-97112ac21e91.png"
