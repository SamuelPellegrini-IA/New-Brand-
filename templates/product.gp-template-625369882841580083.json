  "sections": {
    "gp_section_625369882908688947": {
      "settings": {
        "checksum": "f82822a2e3b5088214cd9916331d30df67c49bf8cf46913679b11473bdcca871_1_1_1_0__1",
        "gg-oS0OaV7f_text": "<p>Verified Buyer</p>",
        "gg-tUtWxKhh_text": "<p>Liam H.</p>",
