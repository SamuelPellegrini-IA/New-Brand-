        "ggtI2wdGFJr_text": "<p><span style=\"background-color:rgb(247,247,247);color:#161616;font-size:16px;\">From Gym To Office, These Boxers Have Your Back (And Everything Else).</span></p>",
        "ggd3OhgA70G_customContent_prefix": "Save",
        "ggd3OhgA70G_customContent_suffix": "OFF",
        "ggEPdQbnkAm_text": "<p>At a quick glance:</p>",
        "ggX3JiVNDxz_text": "<p>4-Way Stretch<br>Durable fabric </p>",
