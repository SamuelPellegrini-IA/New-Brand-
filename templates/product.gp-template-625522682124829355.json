    "gp_section_625522682225951403": {
      "settings": {
        "checksum": "87d480485e284a0342cc8c0a664d27ea61483701256ab9afabecf321134c72e3_1_1_1_0__1",
        "ggEHgpqPnHj_childItem_0": "<p>Item Details</p>",
        "ggEHgpqPnHj_childItem_1": "<p>Shipping Info</p>",
        "ggEHgpqPnHj_childItem_2": "<p>Satisfaction Guarantee</p>",
        "ggMOFdfwuZp_text": "<p>Capture your furry friend's unique personality in a vibrant, custom photo tropical style <a href=\"https://geckocustom.com/collections/personalized-beach-gift\" target=\"_blank\"><strong>Hawaii Shirt</strong></a>! Perfect for the cat lover in your life, it also makes a memorable summer or beach trip gift! Make memories that last with this one-of-a-kind fashion statement!<br>&nbsp;</p><p>Every&nbsp;<a href=\"https://geckocustom.com/collections/personalized-photo-gifts\"><span style=\"color:rgb(22,95,83);\">personalized photo gift</span></a>&nbsp;is special and unique because we upload your photo, which allows you to express exactly how you want your gift to look</p><p><strong>Preview</strong>:<br>- Choose an option and upload your photo.<br>- Click [<strong>Preview Your Personalization</strong>] to see the preview.<br>- Double-check your options before purchasing.</p>",
        "ggVI69kLduJ_text": "<ul><li>Full-refund or replace a new item (No any extra fee within 30 days since your purchase) for faulty, defective or damaged products.</li><li>Full-refund if the item is not as described.</li><li>We have 24/7/365 ticket and email support. Please contact us at&nbsp;<i>support@hapyco.co</i>&nbsp;if you need any assistance.</li><li>For more detailed information and instructions, please visit our&nbsp;<a href=\"https://geckocustom.com/policies/refund-policy\">Refund &amp; Replacement Policy.</a></li></ul>",
        "ggY2hH_XtMS_text": "<ul><li>The above time frame is only applied for orders to the US with standard shipping methods.</li><li>International orders: It may take 2-5 days longer due to the customs clearance process.</li><li><strong>Orders can be cancelled or modified only within 2 hours after being placed.</strong></li><li>Learn more about Shipping Policy&nbsp;<a href=\"https://geckocustom.com/policies/shipping-policy\">here.</a></li><li>For more detailed information and instructions, please visit our<a href=\"https://geckocustom.com/policies/refund-policy\"><span style=\"color:rgb(22,95,83);\">&nbsp;</span>Refund &amp; Replacement Policy.</a></li></ul>"
      },
