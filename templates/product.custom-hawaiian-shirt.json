{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title",
          "settings": {}
        },
        "subtitle": {
          "type": "text",
          "settings": {
            "text": "Personalize it with your own photo — a unique, made-to-order gift they will treasure.",
            "text_style": "body"
          }
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "square"
          }
        },
        "customily_personalizer": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<!-- In the theme editor: remove this block and add the Customily app block(s) here (Product Personalizer / options). Keep Live Preview if it renders separately — the layout script moves preview to the left column automatically. -->"
          }
        },
        "gift_box": {
          "type": "hawaiian_gift_box",
          "settings": {
            "title": "Gift Box For Hawaii Shirt",
            "sale_price": "Only $6.99",
            "compare_price": "$12.99",
            "product_name": "Box For Hawaii Shirt",
            "checkbox_label": "Choose to buy",
            "details_link_text": "View details >",
            "details_url": "",
            "gift_box_variant_id": ""
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        }
      },
      "block_order": [
        "title",
        "subtitle",
        "price",
        "variant_picker",
        "customily_personalizer",
        "gift_box",
        "quantity_selector",
        "buy_buttons",
        "description"
      ],
      "settings": {
        "layout_style": "hawaiian_shirt",
        "enable_sticky_info": false,
        "color_scheme": "scheme-1",
        "media_size": "medium",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "gallery_layout": "thumbnail",
        "mobile_thumbnails": "show",
        "media_position": "left",
        "image_zoom": "lightbox",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 24,
        "padding_bottom": 36
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": "2",
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
