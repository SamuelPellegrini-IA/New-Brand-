            var priceElement = document.querySelector(".option2price h2 span");
            var discountElement = document.querySelector(".option2discount h2 s");
            var eachAmountpriceElement2 = document.querySelector(".eachamount2 strong");
            eachAmountpriceElement2.innerText = "Only " + priceTextEachPack5 + " Each";
        } else if (option1 == "Pack of 5 - 2x Black - 1x Blue - 1x Red - 1x Grey") {
            var priceElement = document.querySelector(".option3price h2 span");
            var discountElement = document.querySelector(".option3discount h2 s");
            var eachAmountpriceElement3 = document.querySelector(".eachamount3 strong");
            eachAmountpriceElement3.innerText = "Only " + priceTextEachPack10 + " Each";
        }
        if (priceElement) {
            priceElement.innerText = priceText;
        }
        if (discountElement) {
            discountElement.innerText = discountAmountRaw;
        }
        {% endunless %}
    {% endif %}
{% endfor %}
</script>
