        var option1 = "{{ variant.option1 }}";
        var priceText = "{{ variant.price | money }}";
        var priceTextEachPack2 = "{{ variant.price | divided_by: 10 | money }}";
        var priceTextEachPack5 = "{{ variant.price | divided_by: 5 | money }}";
        console.log("Option 1: " + option1);
        console.log("Price: " + priceText);
        // Get discount amount
        var discountAmountRaw = "{{ variant.compare_at_price | money }}";
        console.log("Discount Amount: " + discountAmountRaw);
        // Ajuste específico para cada pack
        if (option1 == "1x Black") {
            var priceElement = document.querySelector(".option1price h2 span");
            var discountElement = document.querySelector(".option1discount h2 s");
            var eachAmountpriceElement = document.querySelector(".eachamount1 strong");
            eachAmountpriceElement.innerText = "Only " + priceText + " Each";
