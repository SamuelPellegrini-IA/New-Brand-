{%- comment -%} Renders editable product-page marketing blocks. Param: block {%- endcomment -%}
{%- case block.type -%}

  {%- when 'lp_variant_style' -%}
    {%- liquid
      assign sel_border = block.settings.sel_border | default: '#101936'
      assign sel_text = block.settings.sel_text | default: '#ffffff'
      assign sel_bg = block.settings.sel_bg | default: '#101936'
      assign unsel_border = block.settings.unsel_border | default: '#101936'
      assign unsel_text = block.settings.unsel_text | default: '#1f1f1f'
      assign hover_border = block.settings.hover_border | default: '#101936'
      assign radius = block.settings.radius | default: 4
    -%}
    <style>
      /* Premium product title + subtitle (scoped: only loads on templates using this block) */
      .product__title h1,
      .product__title .h1,
      .product__title h2.h1,
      .custom-hawaiian-product-page .product__title h1,
      .custom-hawaiian-product-page .product__title .h1 {
        font-family: Georgia, "Times New Roman", "Playfair Display", serif !important;
        font-weight: 800 !important;
        color: #101936 !important;
        line-height: 1.18 !important;
        letter-spacing: -.01em !important;
        font-size: clamp(2rem, 2.6vw, 2.6rem) !important;
        margin: 0 0 .8rem !important;
        text-transform: none !important;
      }
      .product__text:not(.caption-with-letter-spacing),
      .custom-hawaiian-product-page .product__text:not(.caption-with-letter-spacing) {
        color: #666666 !important;
        font-size: 1.5rem !important;
        line-height: 1.5 !important;
      }
      /* Variant buttons */
      .product-form__input--pill { margin-bottom: 1.3rem; }
      .product-form__input--pill .form__label { font-weight: 700; font-size: 1.4rem; margin-bottom: .7rem; color: #1f1f1f; }
      .product-form__input--pill input[type='radio'] + label {
        border: 1px solid {{ unsel_border }};
        border-radius: {{ radius }}px;
        padding: 1rem 1.6rem;
        margin: 0 .6rem .6rem 0;
        font-weight: 600;
        color: {{ unsel_text }};
        background: #fff;
        transition: border-color .15s ease, color .15s ease, background .15s ease, box-shadow .15s ease, transform .05s ease;
      }
      .product-form__input--pill input[type='radio']:hover + label { border-color: {{ hover_border }}; }
      .product-form__input--pill input[type='radio']:checked + label {
        border-color: {{ sel_border }} !important;
        color: {{ sel_text }} !important;
        box-shadow: 0 0 0 1px {{ sel_border }} inset !important;
        background: {{ sel_bg }} !important;
      }
      .product-form__input--pill input[type='radio']:active + label { transform: scale(.97); }
      .product-form__input--pill input[type='radio']:disabled + label {
        color: #bbb; border-color: #eee; text-decoration: line-through; cursor: not-allowed; background: #fff;
      }
      .product-form__input--pill input[type='radio']:focus-visible + label {
        outline: 2px solid {{ sel_border }}; outline-offset: 2px;
      }
      {%- unless block.settings.show_more_options -%}
      .shopify-payment-button__more-options { display: none !important; }
      {%- endunless -%}
      {%- if block.settings.tighten_buttons -%}
      .product-form__buttons { margin-top: .8rem !important; margin-bottom: 1rem !important; }
      .product-form__submit { margin-bottom: .6rem !important; }
      .shopify-payment-button { margin-top: 0 !important; }
      .shopify-payment-button__button { margin-bottom: .4rem !important; }
      .gecko-post-atc, .product-checkout-security { margin-top: .6rem !important; }
      {%- endif -%}
    </style>

  {%- when 'lp_size_chart' -%}
    {%- liquid
      assign sc_text = block.settings.sc_text | default: 'size chart'
      assign sc_option = block.settings.sc_option | default: 'Size'
      assign sc_has_content = false
      if block.settings.sc_image != blank or block.settings.sc_richtext != blank
        assign sc_has_content = true
      endif
      assign sc_use_modal = true
      if sc_has_content == false and block.settings.sc_link != blank
        assign sc_use_modal = false
      endif
    -%}
    <style>
      .product-form__input--pill .form__label { display: flex; align-items: center; }
      .lp-size-chart-link {
        margin-left: auto; display: inline-flex; align-items: center; gap: 5px;
        font-size: 13px; font-weight: 500; text-decoration: underline; text-underline-offset: 2px;
        color: #1f1f1f; cursor: pointer; background: none; border: none;
      }
      .lp-size-chart-link svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.6; }
      .lp-scm__overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); display: none; align-items: center; justify-content: center; z-index: 99999; padding: 20px; }
      .lp-scm__overlay.is-open { display: flex; }
      .lp-scm__box { background: #fff; border-radius: 14px; max-width: 900px; width: 100%; max-height: 90vh; overflow: auto; position: relative; padding: 16px; }
      .lp-scm__close { position: absolute; top: 8px; right: 12px; background: none; border: none; font-size: 28px; line-height: 1; cursor: pointer; color: #111; z-index: 1; }
      .lp-scm__title { font-weight: 700; font-size: 18px; margin: 0 0 12px; padding-right: 24px; color: #1f1f1f; }
      .lp-scm__box img { width: 100%; height: auto; display: block; object-fit: contain; border-radius: 8px; }
      .lp-scm__fallback { padding: 28px 8px; text-align: center; color: #666; font-size: 15px; }
    </style>
    {%- if sc_use_modal -%}
      <div class="lp-scm__overlay" id="lp-scm-{{ block.id }}" role="dialog" aria-modal="true" {{ block.shopify_attributes }}>
        <div class="lp-scm__box">
          <button type="button" class="lp-scm__close" aria-label="Fermer">&times;</button>
          {%- if block.settings.sc_title != blank -%}<p class="lp-scm__title">{{ block.settings.sc_title }}</p>{%- endif -%}
          {%- if block.settings.sc_image != blank -%}
            <img src="{{ block.settings.sc_image | image_url: width: 1000 }}" alt="{{ block.settings.sc_title | default: 'Size chart' | escape }}" loading="lazy">
          {%- elsif block.settings.sc_richtext != blank -%}
            <div class="rte">{{ block.settings.sc_richtext }}</div>
          {%- else -%}
            <div class="lp-scm__fallback">Size chart coming soon.</div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    <script>
    (function(){
      var TEXT = {{ sc_text | json }};
      var OPT = {{ sc_option | json }}.toLowerCase();
      var LINK = {{ block.settings.sc_link | default: '' | json }};
      var HAS_MODAL = {% if sc_use_modal %}true{% else %}false{% endif %};
      var overlay = document.getElementById('lp-scm-{{ block.id }}');
      var ICON = '<svg viewBox="0 0 24 24"><path d="M3 8h18v8H3z"/><path d="M7 8v3M11 8v4M15 8v3M19 8v4"/></svg>';
      function openModal(){ if(overlay){ overlay.classList.add('is-open'); document.body.style.overflow = 'hidden'; } }
      function closeModal(){ if(overlay){ overlay.classList.remove('is-open'); document.body.style.overflow = ''; } }
      function inject(){
        var labels = document.querySelectorAll('.product-form__input .form__label, .product-form__input legend');
        for (var i=0;i<labels.length;i++){
          var lbl = labels[i];
          var t = (lbl.textContent||'').trim().toLowerCase();
          if (t.indexOf(OPT) === -1) continue;
          if (lbl.querySelector('.lp-size-chart-link')) continue;
          var a = document.createElement('a');
          a.className = 'lp-size-chart-link';
          a.href = (!HAS_MODAL && LINK) ? LINK : '#';
          if (!HAS_MODAL && LINK){ a.target = '_blank'; a.rel = 'noopener'; }
          a.innerHTML = ICON + '<span>' + TEXT + '</span>';
          a.addEventListener('click', function(e){
            if (HAS_MODAL){ e.preventDefault(); openModal(); }
            else if (!LINK){ e.preventDefault(); }
          });
          lbl.appendChild(a);
        }
      }
      if (overlay){
        overlay.addEventListener('click', function(e){
          if (e.target === overlay || e.target.classList.contains('lp-scm__close')) closeModal();
        });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal(); });
      }
      var scheduled = false;
      function schedule(){ if (scheduled) return; scheduled = true; requestAnimationFrame(function(){ scheduled = false; inject(); }); }
      if (document.readyState !== 'loading') inject(); else document.addEventListener('DOMContentLoaded', inject);
      document.addEventListener('shopify:section:load', inject);
      try { new MutationObserver(schedule).observe(document.body, { childList: true, subtree: true }); } catch(e){}
    })();
    </script>

  {%- when 'lp_trust_badge' -%}
    {%- liquid
      assign full = block.settings.stars | floor
      assign rem = block.settings.stars | minus: full
      assign half_index = full | plus: 1
    -%}
    <div
      style="display:flex;align-items:center;flex-wrap:wrap;gap:8px;font-size:14px;line-height:1.2;margin:2px 0 14px;color:{{ block.settings.text_color }}"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.rating_label != blank -%}
        <span style="font-weight:700">{{ block.settings.rating_label }}</span>
      {%- endif -%}
      <span style="display:inline-flex;gap:2px">
        {%- for i in (1..5) -%}
          {%- if i <= full -%}
            <span style="width:18px;height:18px;background:{{ block.settings.star_color }};display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:11px;border-radius:2px">&#9733;</span>
          {%- elsif i == half_index and rem >= 0.5 -%}
            <span style="width:18px;height:18px;background:linear-gradient(90deg,{{ block.settings.star_color }} 50%,#dcdce6 50%);display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:11px;border-radius:2px">&#9733;</span>
          {%- else -%}
            <span style="width:18px;height:18px;background:#dcdce6;display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:11px;border-radius:2px">&#9733;</span>
          {%- endif -%}
        {%- endfor -%}
      </span>
      <span>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" style="color:inherit;text-decoration:underline">{{ block.settings.reviews_text }}</a>
        {%- else -%}
          <span style="text-decoration:underline">{{ block.settings.reviews_text }}</span>
        {%- endif -%}
        {%- if block.settings.platform_text != blank -%}
          on <strong style="white-space:nowrap;color:{{ block.settings.star_color }}">&#9733; {{ block.settings.platform_text }}</strong>
        {%- endif -%}
      </span>
    </div>

  {%- when 'lp_quick_glance' -%}
    <style>
      #pp-qg-{{ block.id }} .pp-qg__i:first-child{border-left:0;padding-left:0}
      #pp-qg-{{ block.id }} svg{width:30px;height:30px;flex:0 0 30px;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}
      @media(max-width:749px){#pp-qg-{{ block.id }} .pp-qg__i{min-width:46%}}
    </style>
    <div id="pp-qg-{{ block.id }}" style="margin:16px 0;border-top:1px solid {{ block.settings.divider_color }};border-bottom:1px solid {{ block.settings.divider_color }};padding:12px 0" {{ block.shopify_attributes }}>
      {%- if block.settings.heading != blank -%}
        <div style="font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin:0 0 10px;color:{{ block.settings.text_color }}">{{ block.settings.heading }}</div>
      {%- endif -%}
      <div style="display:flex;flex-wrap:wrap">
        {%- for n in (1..4) -%}
          {%- assign icon_key = 'icon_' | append: n -%}
          {%- assign label_key = 'label_' | append: n -%}
          {%- assign lbl = block.settings[label_key] -%}
          {%- if lbl != blank -%}
            <div class="pp-qg__i" style="flex:1 1 0;min-width:130px;display:flex;align-items:center;gap:9px;padding:4px 14px;border-left:1px solid {{ block.settings.divider_color }};font-size:13px;line-height:1.25;font-weight:500;color:{{ block.settings.text_color }}">
              {% render 'lp-pp-icon', name: block.settings[icon_key], color: block.settings.icon_color %}
              <span>{{ lbl }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  {%- when 'lp_price_color' -%}
    {%- liquid
      assign psize = block.settings.price_size | default: 28
      assign csize = psize | times: 60 | divided_by: 100
      assign gap_above = block.settings.gap_above | default: 6
    -%}
    <style>
      /* reduce gap between the text above and the price */
      .product__text { margin: 0 0 {{ gap_above }}px !important; }
      #price-{{ section.id }}, .price { margin-top: 0 !important; }
      {%- if block.settings.hide_tax_line -%}
      .product__tax { display: none !important; }
      {%- endif -%}
      {%- if block.settings.hide_installments -%}
      .installment, shopify-payment-terms { display: none !important; }
      {%- endif -%}
      /* align price row + badge on one centered line */
      .price,
      .price__container {
        display: flex !important;
        align-items: center !important;
        flex-wrap: wrap;
        column-gap: .6rem;
        row-gap: .2rem;
      }
      /* never show both price blocks at once (avoids duplicate price) */
      .price--on-sale .price__regular { display: none !important; }
      .price:not(.price--on-sale) .price__sale { display: none !important; }
      .price--on-sale .price__sale,
      .price:not(.price--on-sale) .price__regular {
        display: flex !important;
        align-items: center;
        flex-wrap: wrap;
        column-gap: .6rem;
        row-gap: .2rem;
      }
      .price .price-item--sale,
      .price__regular .price-item--regular {
        {% if block.settings.price_color != blank %}color: {{ block.settings.price_color }} !important;{% endif %}
        {% if block.settings.bold_price %}font-weight: 800 !important;{% endif %}
        font-size: {{ psize }}px !important;
        line-height: 1 !important;
      }
      .price__sale .price-item--regular {
        font-size: {{ csize }}px !important;
        opacity: .5;
        align-self: center;
      }
      /* The "Save % OFF" badge replaces the default "Sale" badge */
      .price__badge-sale { display: none !important; }
      /* Render the price inline so the Save badge can sit right beside it */
      #price-{{ section.id }} {
        display: inline-flex !important;
        align-items: center !important;
        vertical-align: middle;
      }
      .lp-save-badge-row {
        display: inline-flex !important;
        vertical-align: middle;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0 0 0 .7rem !important;
      }
    </style>

  {%- when 'lp_save_badge' -%}
    {%- assign v = product.selected_or_first_available_variant -%}
    <div class="lp-save-badge-row" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin:8px 0 4px" {{ block.shopify_attributes }}>
      {%- if block.settings.show_save and v.compare_at_price > v.price -%}
        {%- assign pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round -%}
        <span style="display:inline-flex;align-items:center;background:{{ block.settings.save_bg }};color:{{ block.settings.save_text_color }};font-weight:700;font-size:13px;padding:5px 12px;border-radius:999px;line-height:1.2;white-space:nowrap">{{ block.settings.save_prefix }} {{ pct }}% {{ block.settings.save_suffix }}</span>
      {%- endif -%}
      {%- if block.settings.per_piece_text != blank -%}
        <span style="display:inline-flex;align-items:center;background:{{ block.settings.pp_bg }};color:{{ block.settings.pp_text_color }};font-weight:600;font-size:13px;padding:5px 12px;border-radius:999px;line-height:1.2;white-space:nowrap">{{ block.settings.per_piece_text }}</span>
      {%- endif -%}
    </div>

  {%- when 'lp_fit_bar' -%}
    <div style="background:{{ block.settings.bg_color }};color:{{ block.settings.text_color }};border-radius:8px;padding:10px 14px;font-size:13px;display:flex;align-items:center;gap:9px;margin:14px 0;line-height:1.3" {{ block.shopify_attributes }}>
      {%- if block.settings.show_icon -%}
        <svg viewBox="0 0 24 24" style="width:18px;height:18px;flex:0 0 18px;stroke:{{ block.settings.icon_color }};fill:none;stroke-width:1.7"><circle cx="12" cy="8" r="3.2"/><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"/></svg>
      {%- endif -%}
      <span>{{ block.settings.text }}</span>
    </div>

  {%- when 'lp_low_stock' -%}
    <div style="border:1px solid {{ block.settings.border_color }};background:{{ block.settings.bg_color }};color:{{ block.settings.text_color }};border-radius:10px;padding:16px;margin:14px 0;font-size:13px;line-height:1.55" {{ block.shopify_attributes }}>
      {%- if block.settings.heading != blank -%}
        <div style="display:flex;align-items:center;gap:8px;font-weight:700;font-size:15px;margin:0 0 8px;color:{{ block.settings.heading_color }}">
          <svg viewBox="0 0 24 24" style="width:20px;height:20px;flex:0 0 20px;stroke:{{ block.settings.icon_color }};fill:none;stroke-width:1.7"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11.2 11.5h1v4.5"/></svg>
          {{ block.settings.heading }}
        </div>
      {%- endif -%}
      <div class="rte">{{ block.settings.body }}</div>
      {%- if block.settings.ps_text != blank -%}<div class="rte">{{ block.settings.ps_text }}</div>{%- endif -%}
    </div>

{%- endcase -%}
