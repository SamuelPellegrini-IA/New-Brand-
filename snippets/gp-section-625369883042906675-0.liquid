<script>
  (function () {
    function initDeliveryDates() {
      const SHIP_START_DAYS = 2;
      const SHIP_END_DAYS = 3;
      const ARRIVAL_START_DAYS = 12;
      const ARRIVAL_END_DAYS = 15;

      function getTodayInUS() {
        const formatter = new Intl.DateTimeFormat("en-US", {
          timeZone: "America/New_York",
          year: "numeric",
          month: "numeric",
          day: "numeric"
        });

        const parts = formatter.formatToParts(new Date());
        const year = Number(parts.find(part => part.type === "year").value);
        const month = Number(parts.find(part => part.type === "month").value);
        const day = Number(parts.find(part => part.type === "day").value);

        return new Date(year, month - 1, day);
      }

      function addDays(date, days) {
        const result = new Date(date);
        result.setDate(result.getDate() + days);
        return result;
      }

      function formatSingleDate(date) {
        return date.toLocaleDateString("en-US", {
          month: "short",
          day: "2-digit"
        });
      }

      function formatRange(start, end) {
        const startMonth = start.toLocaleDateString("en-US", { month: "short" });
        const endMonth = end.toLocaleDateString("en-US", { month: "short" });

        const startDay = start.toLocaleDateString("en-US", { day: "2-digit" });
        const endDay = end.toLocaleDateString("en-US", { day: "2-digit" });

        if (startMonth === endMonth) {
          return startMonth + " " + startDay + " – " + endDay;
        }

        return startMonth + " " + startDay + " – " + endMonth + " " + endDay;
      }

      const today = getTodayInUS();

      const orderDate = today;
      const shipStart = addDays(today, SHIP_START_DAYS);
      const shipEnd = addDays(today, SHIP_END_DAYS);
      const arrivalStart = addDays(today, ARRIVAL_START_DAYS);
      const arrivalEnd = addDays(today, ARRIVAL_END_DAYS);

      const orderText = formatSingleDate(orderDate);
      const shipText = formatRange(shipStart, shipEnd);
      const arrivalText = formatRange(arrivalStart, arrivalEnd);

      const orderEl = document.getElementById("bh-order-date");
      const shipEl = document.getElementById("bh-ship-date");
      const arrivalEl = document.getElementById("bh-arrival-date");
      const headerArrivalEl = document.getElementById("bh-arrives-header");

      if (orderEl) orderEl.textContent = orderText;
      if (shipEl) shipEl.textContent = shipText;
      if (arrivalEl) arrivalEl.textContent = arrivalText;
      if (headerArrivalEl) headerArrivalEl.textContent = arrivalText;
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initDeliveryDates);
    } else {
      initDeliveryDates();
    }
  })();
</script>
