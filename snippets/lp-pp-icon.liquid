{%- comment -%} Renders a line icon by name for product-page blocks. Params: name, color {%- endcomment -%}
{%- liquid
  assign c = color | default: '#111111'
-%}
{%- case name -%}
  {%- when 'camera' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><rect x="3" y="7" width="18" height="13" rx="2"/><circle cx="12" cy="13.5" r="3.4"/><path d="M8.5 7l1.3-2h4.4l1.3 2"/></svg>
  {%- when 'check' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l2.7 2.7L16 9.5"/></svg>
  {%- when 'drop' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M12 3s6 6.4 6 11a6 6 0 1 1-12 0c0-4.6 6-11 6-11z"/></svg>
  {%- when 'leaf' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M20 4S8 4 6 12c-1 4 2 8 6 8 8-2 8-16 8-16z"/><path d="M9 15c3-3 6-4 9-5"/></svg>
  {%- when 'shield' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M12 3l7 3v6c0 5-3 7-7 9-4-2-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>
  {%- when 'truck' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17.5" cy="18" r="1.6"/></svg>
  {%- when 'lock' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><rect x="5" y="10" width="14" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
  {%- when 'heart' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M12 20s-7-4.4-7-9.5A3.8 3.8 0 0 1 12 7a3.8 3.8 0 0 1 7 3.5C19 15.6 12 20 12 20z"/></svg>
  {%- when 'medal' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><circle cx="12" cy="9" r="5"/><path d="M9 13l-2 7 5-3 5 3-2-7"/></svg>
  {%- when 'gift' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><rect x="4" y="9" width="16" height="11" rx="1"/><path d="M3 9h18M12 9v11M12 9S9 3 6.5 4.5 9 9 12 9zm0 0s3-6 5.5-4.5S15 9 12 9z"/></svg>
  {%- when 'ruler' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><rect x="3" y="8" width="18" height="8" rx="1"/><path d="M7 8v3M11 8v4M15 8v3M19 8v4"/></svg>
  {%- when 'recycle' -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M7 9l-3 5 3 2"/><path d="M10 5l2-3 3 5"/><path d="M20 13l1 4-5 1"/><path d="M4 14h4M15 7l2 3M9 19h5"/></svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" style="stroke:{{ c }}"><path d="M12 3l2.2 5.3 5.8 .5-4.4 3.8 1.3 5.6L12 15.9 7.1 18.8l1.3-5.6L4 9.8l5.8-.5z"/></svg>
{%- endcase -%}
