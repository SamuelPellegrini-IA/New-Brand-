      <style id="custom-css-g1U-ibZl4Z">
        /* === PDP Low Stock Notice – Optimized Typography === */

.lsn {
  padding: 18px 20px;
  border-radius: 14px;
}

/* Header */
.lsn__head {
  gap: 10px;
  margin-bottom: 10px;
}

.lsn__icon {
  width: 24px;
  height: 24px;
}

.lsn__icon svg {
  width: 24px;
  height: 24px;
}

/* Title */
.lsn__title {
  font-size: 20px;          /* ↓ from 34px */
  line-height: 1.2;
  letter-spacing: -0.2px;
  font-weight: 700;
}

/* Body copy */
.lsn__body {
  font-size: 15px;          /* ↓ from 24px */
  line-height: 1.45;
  color: #7a7a7a;
}

.lsn__body p + p {
  margin-top: 8px;
}

/* Emphasis */
.lsn__body strong {
  font-weight: 700;
  color: #2a2a2a;
}

/* Links */
.lsn__link {
  text-decoration-thickness: 1.5px;
  text-underline-offset: 3px;
}

/* PS line */
.lsn__ps {
  font-size: 14px;
}

/* Mobile */
@media (max-width: 768px) {
  .lsn {
    padding: 16px;
  }

  .lsn__title {
    font-size: 18px;
  }

  .lsn__body {
    font-size: 14px;
  }
}

      </style>
    
    

    

    
