{%- liquid
  assign has_rating = false
  assign has_gift = false
  assign has_preview = false
  assign tab_count = 0

  for gecko_block in section.blocks
    case gecko_block.type
      when 'hawaiian_product_rating'
        assign has_rating = true
      when 'hawaiian_gift_box'
        assign has_gift = true
      when 'hawaiian_preview_button'
        assign has_preview = true
      when 'collapsible_tab'
        assign tab_count = tab_count | plus: 1
    endcase
  endfor
-%}

{%- if slot == 'after_title' and has_rating == false -%}
  <div class="gecko-product-rating">
    <a href="#customer-reviews" class="gecko-product-rating__link">
      <span class="gecko-product-rating__stars" style="--rating-pct: 98%;" aria-hidden="true"></span>
      <span class="gecko-product-rating__count">5066 reviews</span>
    </a>
  </div>
{%- endif -%}

{%- if slot == 'after_price' and has_gift == false -%}
  <div class="gecko-gift-box" data-hawaiian-gift-box>
    <div class="gecko-gift-box__header">Gift Box For Hawaii Shirt</div>
    <div class="gecko-gift-box__body">
      <div class="gecko-gift-box__left">
        <div class="gecko-gift-box__image gecko-gift-box__image--placeholder" aria-hidden="true">📦</div>
        <span class="gecko-gift-box__details-link">View details &gt;</span>
      </div>
      <div class="gecko-gift-box__right">
        <p class="gecko-gift-box__price">
          <span class="gecko-gift-box__price-sale">Only $6.99</span>
          <span class="gecko-gift-box__price-compare">$12.99</span>
        </p>
        <p class="gecko-gift-box__name">Box For Hawaii Shirt</p>
        <label class="gecko-gift-box__checkbox">
          <input type="checkbox" name="properties[Gift Box]" value="Yes">
          <span>Choose to buy</span>
        </label>
      </div>
    </div>
  </div>
{%- endif -%}

{%- if slot == 'before_buy' and has_preview == false -%}
  <button type="button" class="gecko-preview-btn" data-gecko-preview-trigger>
    Preview Your Personalization
  </button>
{%- endif -%}

{%- if slot == 'after_blocks' and tab_count == 0 -%}
  <div class="gecko-accordions">
    <div class="product__accordion accordion quick-add-hidden">
      <details id="Details-gecko-details-{{ section.id }}">
        <summary>
          <div class="summary__title">
            <h2 class="h4 accordion__title inline-richtext">Item details</h2>
          </div>
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </summary>
        <div class="accordion__content rte">
          <p>Capture your furry friend's unique personality in a vibrant, custom photo tropical style <strong>cat Hawaii Shirt</strong>!</p>
          <p><strong>Processing Time:</strong> 3–5 business days<br><strong>Shipping Time:</strong> 10–15 business days</p>
        </div>
      </details>
    </div>
    <div class="product__accordion accordion quick-add-hidden">
      <details id="Details-gecko-shipping-{{ section.id }}">
        <summary>
          <div class="summary__title">
            <h2 class="h4 accordion__title inline-richtext">Shipping Info</h2>
          </div>
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </summary>
        <div class="accordion__content rte">
          <p>All products are made to order. US standard shipping: 10–15 business days after processing.</p>
        </div>
      </details>
    </div>
    <div class="product__accordion accordion quick-add-hidden">
      <details id="Details-gecko-guarantee-{{ section.id }}">
        <summary>
          <div class="summary__title">
            <h2 class="h4 accordion__title inline-richtext">Satisfaction Guarantee</h2>
          </div>
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </summary>
        <div class="accordion__content rte">
          <p>Full refund or replacement within 30 days for faulty or defective products.</p>
        </div>
      </details>
    </div>
    <div class="product__accordion accordion quick-add-hidden">
      <details id="Details-gecko-deals-{{ section.id }}">
        <summary>
          <div class="summary__title">
            <h2 class="h4 accordion__title inline-richtext">Hot Deals</h2>
          </div>
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </summary>
        <div class="accordion__content rte">
          <p><strong>Enjoy an exclusive 10% discount using code HOT10.</strong></p>
        </div>
      </details>
    </div>
  </div>
{%- endif -%}
