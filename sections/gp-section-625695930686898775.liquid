    <style>
@media only screen and (max-width: 768px) {
  #mobile-preview-btn {
    position: fixed !important;
    bottom: 14px !important;
    left: 14px !important;
    right: 14px !important;
    z-index: 999999 !important;
    background: #FFD814 !important;
    color: #111 !important;
    border: 1px solid #e0bd00 !important;
    border-radius: 12px !important;
    padding: 15px 18px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    text-align: center !important;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18) !important;
    display: none !important;
  }

  #mobile-preview-btn.is-visible {
    display: block !important;
  }

  #mobile-preview-modal {
    position: fixed !important;
    inset: 0 !important;
    z-index: 9999999 !important;
    background: rgba(0,0,0,0.72) !important;
    display: none !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 18px !important;
  }

  #mobile-preview-modal.is-open {
    display: flex !important;
  }

  #mobile-preview-box {
    position: relative !important;
    width: 100% !important;
    max-width: 420px !important;
    background: #fff !important;
    border-radius: 16px !important;
    padding: 16px !important;
    box-shadow: 0 12px 40px rgba(0,0,0,0.25) !important;
  }

  #mobile-preview-title {
    font-size: 17px !important;
    font-weight: 800 !important;
    margin: 0 35px 12px 0 !important;
    color: #111 !important;
  }

  #mobile-preview-close {
    position: absolute !important;
    top: 8px !important;
    right: 12px !important;
    background: transparent !important;
    border: none !important;
    font-size: 30px !important;
    line-height: 1 !important;
    color: #111 !important;
    z-index: 2 !important;
  }

  #mobile-preview-content {
    min-height: 260px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  #mobile-preview-content img,
  #mobile-preview-content canvas,
  #mobile-preview-content svg {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    display: block !important;
    border-radius: 10px !important;
  }

  body.mobile-preview-open {
    overflow: hidden !important;
    position: fixed !important;
    width: 100% !important;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  if (window.innerWidth > 768) return;

  let savedScrollY = 0;
  let hasStarted = false;

  const previewBtn = document.createElement("button");
  previewBtn.id = "mobile-preview-btn";
  previewBtn.type = "button";
  previewBtn.innerText = "Preview Your Design";
  document.body.appendChild(previewBtn);

  const modal = document.createElement("div");
  modal.id = "mobile-preview-modal";
  modal.innerHTML = `
    <div id="mobile-preview-box">
      <button id="mobile-preview-close" type="button">×</button>
      <div id="mobile-preview-title">Your Preview</div>
      <div id="mobile-preview-content"></div>
    </div>
  `;
  document.body.appendChild(modal);

  const previewContent = document.getElementById("mobile-preview-content");
  const closeBtn = document.getElementById("mobile-preview-close");

  function saveScroll() {
    savedScrollY = window.scrollY || document.documentElement.scrollTop || 0;
  }

  function restoreScroll() {
    setTimeout(function () {
      window.scrollTo(0, savedScrollY);
    }, 30);

    setTimeout(function () {
      window.scrollTo(0, savedScrollY);
    }, 180);
  }

  function showPreviewButton() {
    hasStarted = true;
    previewBtn.classList.add("is-visible");
  }

  function findPreviewElement() {
    const selectors = [
      ".ym-mobile-preview-source img",
      ".ym-mobile-preview-source canvas",
      ".ym-mobile-preview-source svg",

      ".customily-preview img",
      ".customily-preview canvas",
      ".customily-product-preview img",
      ".customily-product-preview canvas",

      ".product-personalizer-preview img",
      ".product-personalizer-preview canvas",

      ".preview img",
      ".preview canvas",
      ".preview svg",

      ".gf_product-image img",
      ".gf_product-gallery img",
      ".gf_product-images img",

      ".product__media img",
      ".product-media img",
      ".swiper-slide-active img",
      ".slick-current img"
    ];

    for (const selector of selectors) {
      const el = document.querySelector(selector);

      if (!el) continue;

      const rect = el.getBoundingClientRect();

      if (rect.width > 80 && rect.height > 80) {
        return el;
      }
    }

    return null;
  }

  function cloneCanvas(canvas) {
    const img = document.createElement("img");
    try {
      img.src = canvas.toDataURL("image/png");
      return img;
    } catch (e) {
      return canvas.cloneNode(true);
    }
  }

  function openPreview() {
    saveScroll();

    const previewEl = findPreviewElement();
    previewContent.innerHTML = "";

    if (previewEl) {
      let clone;

      if (previewEl.tagName.toLowerCase() === "canvas") {
        clone = cloneCanvas(previewEl);
      } else {
        clone = previewEl.cloneNode(true);
      }

      previewContent.appendChild(clone);
    } else {
      previewContent.innerHTML = `
        <div style="padding:32px;text-align:center;font-weight:700;color:#111;">
          Preview loading...<br>
          <span style="font-weight:500;font-size:14px;color:#555;">
            Choose any option to generate your preview.
          </span>
        </div>
      `;
    }

    document.body.style.top = "-" + savedScrollY + "px";
    document.body.classList.add("mobile-preview-open");
    modal.classList.add("is-open");

    restoreScroll();
  }

  function closePreview() {
    modal.classList.remove("is-open");
    document.body.classList.remove("mobile-preview-open");
    document.body.style.top = "";

    window.scrollTo(0, savedScrollY);
  }

  previewBtn.addEventListener("click", function (e) {
    e.preventDefault();
    e.stopPropagation();

    openPreview();
    return false;
  });

  closeBtn.addEventListener("click", function (e) {
    e.preventDefault();
    closePreview();
  });

  modal.addEventListener("click", function (e) {
    if (e.target === modal) {
      closePreview();
    }
  });

  function handlePersonalizationInteraction() {
    saveScroll();
    showPreviewButton();

    restoreScroll();
  }

  document.addEventListener("input", function (e) {
    if (e.target.matches("input, textarea, select")) {
      handlePersonalizationInteraction();
    }
  }, true);

  document.addEventListener("change", function (e) {
    if (e.target.matches("input, textarea, select")) {
      handlePersonalizationInteraction();
    }
  }, true);

  document.addEventListener("click", function (e) {
    const target = e.target.closest(
      "input, textarea, select, button, label, .customily, .product-form, .gf_product, .product-personalizer, .personalizer, .upload, .color-swatch, .swatch"
    );

    if (target && target.id !== "mobile-preview-btn" && target.id !== "mobile-preview-close") {
      handlePersonalizationInteraction();
    }
  }, true);

  document.addEventListener("touchstart", function () {
    saveScroll();
  }, { passive: true });
});
</script>
