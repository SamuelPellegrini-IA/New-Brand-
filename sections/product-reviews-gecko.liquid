{{ 'component-gecko-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign avg = section.settings.average_rating | times: 1.0
  assign avg_pct = avg | divided_by: 5.0 | times: 100
  assign uid = section.id
-%}

<section class="gecko-reviews section-{{ section.id }}-padding" id="gecko-reviews-{{ uid }}">
  <div class="gecko-reviews__wrap page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="gecko-reviews__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="gecko-reviews__summary">
      <div class="gecko-reviews__avg">
        <div class="gecko-stars gecko-stars--lg" style="--p: {{ avg_pct }}%;" role="img" aria-label="{{ section.settings.average_rating }} / 5"></div>
        <div class="gecko-reviews__avg-num">{{ section.settings.average_rating }} out of 5</div>
        <div class="gecko-reviews__total">{{ section.settings.total_label | escape }}</div>
      </div>

      <div class="gecko-reviews__bars">
        {%- for i in (1..5) reversed -%}
          {%- liquid
            assign pct_key = 'pct_' | append: i
            assign cnt_key = 'count_' | append: i
            assign pct = section.settings[pct_key]
            assign cnt = section.settings[cnt_key]
          -%}
          <div class="gecko-reviews__bar-row">
            <span class="gecko-reviews__bar-label">{{ i }} <span class="gecko-stars gecko-stars--xs" style="--p:100%;" aria-hidden="true"></span></span>
            <div class="gecko-reviews__bar-track"><div class="gecko-reviews__bar-fill" style="width: {{ pct }}%;"></div></div>
            <span class="gecko-reviews__bar-count">{{ cnt }}</span>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_write_button -%}
        <div class="gecko-reviews__write">
          <a class="gecko-reviews__write-btn" href="{{ section.settings.write_button_link | default: '#' }}">{{ section.settings.write_button_label | escape }}</a>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.filter_label != blank -%}
      <div class="gecko-reviews__filter">
        <button type="button" class="gecko-reviews__filter-btn" aria-expanded="false">{{ section.settings.filter_label | escape }} ▾</button>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="gecko-reviews__list" data-gecko-reviews-list data-per-page="{{ section.settings.reviews_per_page }}">
        {%- for block in section.blocks -%}
          {%- liquid
            assign r = block.settings.rating | times: 1.0
            assign r_pct = r | divided_by: 5.0 | times: 100
          -%}
          <article class="gecko-reviews__item" data-review-item {{ block.shopify_attributes }}>
            <div class="gecko-reviews__item-head">
              <div class="gecko-stars" style="--p: {{ r_pct }}%;" role="img" aria-label="{{ block.settings.rating }} / 5"></div>
              {%- if block.settings.date != blank -%}
                <time class="gecko-reviews__date">{{ block.settings.date | escape }}</time>
              {%- endif -%}
            </div>
            <div class="gecko-reviews__author-row">
              <span class="gecko-reviews__author">{{ block.settings.author | escape }}</span>
              {%- if block.settings.verified -%}
                <span class="gecko-reviews__verified">{{ block.settings.verified_label | escape }}</span>
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="gecko-reviews__item-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            <div class="gecko-reviews__item-text rte">{{ block.settings.content }}</div>
            {%- liquid
              assign has_photos = false
              if block.settings.review_photo != blank or block.settings.review_photo_2 != blank or block.settings.review_photo_3 != blank or block.settings.review_photo_4 != blank
                assign has_photos = true
              endif
            -%}
            {%- if has_photos -%}
              <div class="gecko-reviews__photos">
                {%- for i in (1..4) -%}
                  {%- capture photo_key -%}review_photo{% if i > 1 %}_{{ i }}{% endif %}{%- endcapture -%}
                  {%- assign photo = block.settings[photo_key] -%}
                  {%- if photo != blank -%}
                    <a href="{{ photo | image_url: width: 1200 }}" target="_blank" rel="noopener">
                      <img src="{{ photo | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy">
                    </a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
            <div class="gecko-reviews__votes">
              <button type="button" class="gecko-reviews__vote" aria-label="Helpful">👍 <span>{{ block.settings.thumbs_up | default: 0 }}</span></button>
              <button type="button" class="gecko-reviews__vote" aria-label="Not helpful">👎 <span>{{ block.settings.thumbs_down | default: 0 }}</span></button>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_pagination -%}
        <nav class="gecko-reviews__pagination" data-gecko-reviews-pagination aria-label="Pagination avis">
          {%- assign total_pages = section.settings.pagination_pages | default: 3 -%}
          {%- for p in (1..total_pages) -%}
            <button type="button" class="gecko-reviews__page{% if p == 1 %} is-active{% endif %}" data-page="{{ p }}">{{ p }}</button>
          {%- endfor -%}
          <button type="button" class="gecko-reviews__page gecko-reviews__page--next" data-page="next" aria-label="Suivant">›</button>
        </nav>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<script src="{{ 'gecko-reviews.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Avis clients Gecko",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "At GeckoCustom We Fight Fake Reviews!" },
    { "type": "header", "content": "Résumé des notes" },
    { "type": "text", "id": "average_rating", "label": "Note moyenne (sur 5)", "default": "4.89" },
    { "type": "text", "id": "total_label", "label": "Texte total avis", "default": "Based on 5066 reviews" },
    { "type": "range", "id": "pct_5", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "5 étoiles (%)", "default": 91 },
    { "type": "text", "id": "count_5", "label": "Nombre 5 étoiles", "default": "4619" },
    { "type": "range", "id": "pct_4", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "4 étoiles (%)", "default": 6 },
    { "type": "text", "id": "count_4", "label": "Nombre 4 étoiles", "default": "300" },
    { "type": "range", "id": "pct_3", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "3 étoiles (%)", "default": 2 },
    { "type": "text", "id": "count_3", "label": "Nombre 3 étoiles", "default": "100" },
    { "type": "range", "id": "pct_2", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "2 étoiles (%)", "default": 1 },
    { "type": "text", "id": "count_2", "label": "Nombre 2 étoiles", "default": "30" },
    { "type": "range", "id": "pct_1", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "1 étoile (%)", "default": 0 },
    { "type": "text", "id": "count_1", "label": "Nombre 1 étoile", "default": "17" },
    { "type": "header", "content": "Bouton écrire un avis" },
    { "type": "checkbox", "id": "show_write_button", "label": "Afficher le bouton", "default": true },
    { "type": "text", "id": "write_button_label", "label": "Texte du bouton", "default": "Write a review" },
    { "type": "url", "id": "write_button_link", "label": "Lien du bouton" },
    { "type": "text", "id": "filter_label", "label": "Label filtre", "default": "Pictures First" },
    { "type": "header", "content": "Pagination" },
    { "type": "checkbox", "id": "show_pagination", "label": "Afficher la pagination", "default": true },
    { "type": "range", "id": "pagination_pages", "min": 1, "max": 10, "step": 1, "label": "Nombre de pages", "default": 3 },
    { "type": "range", "id": "reviews_per_page", "min": 1, "max": 10, "step": 1, "label": "Avis par page", "default": 3 },
    { "type": "header", "content": "Espacement" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Marge haut", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Marge bas", "default": 48 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis",
      "settings": [
        { "type": "text", "id": "author", "label": "Auteur", "default": "David E." },
        { "type": "text", "id": "date", "label": "Date", "default": "06/08/2026" },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Note", "default": 5 },
        { "type": "text", "id": "title", "label": "Titre", "default": "The shirt is of good quality" },
        { "type": "richtext", "id": "content", "label": "Texte", "default": "<p>It is rare to find a company that delivers exactly what you ordered. It arrived in a timely manner and was exactly as pictured.</p>" },
        { "type": "image_picker", "id": "review_photo", "label": "Photo 1" },
        { "type": "image_picker", "id": "review_photo_2", "label": "Photo 2" },
        { "type": "image_picker", "id": "review_photo_3", "label": "Photo 3" },
        { "type": "image_picker", "id": "review_photo_4", "label": "Photo 4" },
        { "type": "checkbox", "id": "verified", "label": "Acheteur vérifié", "default": true },
        { "type": "text", "id": "verified_label", "label": "Label vérifié", "default": "Verified" },
        { "type": "number", "id": "thumbs_up", "label": "Pouces levés", "default": 3 },
        { "type": "number", "id": "thumbs_down", "label": "Pouces baissés", "default": 0 }
      ]
    }
  ],
  "presets": [{ "name": "Avis clients Gecko" }]
}
{% endschema %}
