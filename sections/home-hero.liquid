{%- comment -%}
  Home · Hero
  Simple two-column hero: text + CTA on one side, image on the other.
  All copy and images are editable from the Theme Editor (image_picker = add
  images directly from Shopify). Self-contained, responsive, no dependencies.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .home-hero {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
  }
  #shopify-section-{{ section.id }} .home-hero__inner {
    max-width: 1200px; margin: 0 auto; padding: 0 20px;
    display: grid; gap: 32px; align-items: center;
    grid-template-columns: 1fr;
  }
  #shopify-section-{{ section.id }} .home-hero__media { order: -1; }
  #shopify-section-{{ section.id }} .home-hero__img {
    width: 100%; height: auto; display: block; border-radius: 18px;
    object-fit: cover; box-shadow: 0 18px 50px rgba(0,0,0,.10);
  }
  #shopify-section-{{ section.id }} .home-hero__img-placeholder {
    width: 100%; aspect-ratio: 4 / 3; border-radius: 18px;
    background: rgba(0,0,0,.06); display: flex; align-items: center; justify-content: center;
  }
  #shopify-section-{{ section.id }} .home-hero__img-placeholder svg { width: 90px; height: 90px; opacity: .3; }
  #shopify-section-{{ section.id }} .home-hero__eyebrow {
    display: inline-block; font-size: 13px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: {{ section.settings.accent_color }}; margin: 0 0 14px;
  }
  #shopify-section-{{ section.id }} .home-hero__title {
    font-size: clamp(30px, 5vw, 52px); line-height: 1.08; font-weight: 800; margin: 0 0 16px;
  }
  #shopify-section-{{ section.id }} .home-hero__subtitle {
    font-size: clamp(16px, 2vw, 19px); line-height: 1.55; margin: 0 0 26px; opacity: .85; max-width: 540px;
  }
  #shopify-section-{{ section.id }} .home-hero__cta { display: flex; flex-wrap: wrap; gap: 14px; }
  #shopify-section-{{ section.id }} .home-hero__btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 15px 30px; border-radius: 999px; font-weight: 700; font-size: 16px;
    text-decoration: none; transition: transform .15s ease, opacity .15s ease; cursor: pointer;
  }
  #shopify-section-{{ section.id }} .home-hero__btn:hover { transform: translateY(-2px); }
  #shopify-section-{{ section.id }} .home-hero__btn--primary { background: {{ section.settings.accent_color }}; color: {{ section.settings.btn_text_color }}; }
  #shopify-section-{{ section.id }} .home-hero__btn--secondary { background: transparent; color: {{ section.settings.text_color }}; border: 2px solid currentColor; }
  #shopify-section-{{ section.id }} .home-hero__rating { display: flex; align-items: center; gap: 8px; margin: 22px 0 0; font-size: 14px; opacity: .9; }
  #shopify-section-{{ section.id }} .home-hero__stars { color: {{ section.settings.accent_color }}; letter-spacing: 2px; font-size: 16px; }

  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .home-hero { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
    #shopify-section-{{ section.id }} .home-hero__inner { grid-template-columns: 1fr 1fr; gap: 56px; }
    #shopify-section-{{ section.id }} .home-hero__media { order: {% if section.settings.image_position == 'left' %}-1{% else %}1{% endif %}; }
  }
{%- endstyle -%}

<div class="home-hero">
  <div class="home-hero__inner">
    <div class="home-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="home-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="home-hero__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <div class="home-hero__subtitle">{{ section.settings.subheading }}</div>
      {%- endif -%}
      <div class="home-hero__cta">
        {%- if section.settings.button_label != blank -%}
          <a class="home-hero__btn home-hero__btn--primary" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a class="home-hero__btn home-hero__btn--secondary" href="{{ section.settings.button_link_2 | default: '#' }}">{{ section.settings.button_label_2 }}</a>
        {%- endif -%}
      </div>
      {%- if section.settings.rating_text != blank -%}
        <div class="home-hero__rating">
          <span class="home-hero__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span>{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}
    </div>

    <div class="home-hero__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'eager', class: 'home-hero__img', sizes: '(min-width: 900px) 50vw, 100vw', widths: '600, 900, 1200, 1600' }}
      {%- else -%}
        <div class="home-hero__img-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Home · Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Custom photo gifts" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Turn your pet's photo into a one-of-a-kind shirt" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>Upload a photo, we design it by hand, and you wear your best friend everywhere you go. A unique, made-to-order gift they will treasure.</p>" },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Personalize yours" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary button" },
    { "type": "url", "id": "button_link_2", "label": "Secondary button link" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "Loved by 50,000+ happy customers" },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    {
      "type": "select", "id": "image_position", "label": "Image position (desktop)",
      "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ],
      "default": "right"
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#f6f5f1" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#1a1a1a" },
    { "type": "color", "id": "accent_color", "label": "Accent / button", "default": "#0f7a6b" },
    { "type": "color", "id": "btn_text_color", "label": "Button text", "default": "#ffffff" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 2, "unit": "px", "default": 90 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 2, "unit": "px", "default": 90 }
  ],
  "presets": [ { "name": "Home · Hero" } ]
}
{% endschema %}
