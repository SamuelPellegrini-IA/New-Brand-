    <style>
@media only screen and (max-width: 768px) {
  #hapyco-customily-preview-btn {
    position: fixed !important;
    left: 14px !important;
    right: 14px !important;
    bottom: 14px !important;
    width: calc(100% - 28px) !important;
    z-index: 99999999 !important;

    display: none !important;
    align-items: center !important;
    justify-content: center !important;

    background: #FFD814 !important;
    color: #111 !important;
    border: 1px solid #e0bd00 !important;
    border-radius: 12px !important;

    padding: 15px 18px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
    text-align: center !important;

    box-shadow: 0 8px 22px rgba(0,0,0,0.22) !important;
    cursor: pointer !important;
    -webkit-tap-highlight-color: transparent !important;
  }

  #hapyco-customily-preview-btn.is-visible {
    display: flex !important;
  }

  body.hapyco-preview-active-padding {
    padding-bottom: 84px !important;
  }
}
</style>

<script>
(function () {
  if (window.innerWidth > 768) return;

  const SETTINGS = {
    stickyButtonText: "Preview Your Design",
    autoOpenAfterImageUpload: true,
    autoRefreshAfterOptionChange: true,
    imageUploadDelay: 1000,
    optionRefreshDelay: 450,
    debug: false
  };

  let hasImageUploaded = false;
  let lastGoodScrollY = 0;
  let refreshTimer = null;
  let scrollLockUntil = 0;

  function log() {
    if (SETTINGS.debug) console.log.apply(console, arguments);
  }

  function getScrollY() {
    return window.scrollY || document.documentElement.scrollTop || 0;
  }

  function saveScroll() {
    lastGoodScrollY = getScrollY();
  }

  function protectScroll() {
    const targetY = lastGoodScrollY;
    scrollLockUntil = Date.now() + 1200;

    [50, 120, 250, 500, 850, 1200].forEach(function (delay) {
      setTimeout(function () {
        const currentY = getScrollY();

        /*
          Corrige seulement si Customily/GemPages remonte vers le haut.
          Si le client scroll normalement vers le bas, on ne bloque pas.
        */
        if (Date.now() < scrollLockUntil && currentY < targetY - 120) {
          window.scrollTo({
            top: targetY,
            left: 0,
            behavior: "auto"
          });
        }
      }, delay);
    });
  }

  function normalizeText(text) {
    return String(text || "")
      .trim()
      .toLowerCase()
      .replace(/\s+/g, " ");
  }

  function getElementText(el) {
    if (!el) return "";

    return normalizeText(
      el.innerText ||
      el.textContent ||
      el.value ||
      el.getAttribute("aria-label") ||
      el.getAttribute("title") ||
      ""
    );
  }

  function isVisibleEnough(el) {
    if (!el) return false;

    const rect = el.getBoundingClientRect();
    const style = window.getComputedStyle(el);

    return (
      rect.width > 0 &&
      rect.height > 0 &&
      style.display !== "none" &&
      style.visibility !== "hidden"
    );
  }

  function elementLooksCustomily(el) {
    if (!el) return false;

    const html = normalizeText(el.outerHTML || "");
    const closest = el.closest("div, section, form, product-form, customily-options");
    const parentHtml = closest ? normalizeText(closest.outerHTML || "") : "";

    return (
      html.includes("customily") ||
      parentHtml.includes("customily") ||
      html.includes("personaliz") ||
      parentHtml.includes("personaliz") ||
      html.includes("personaliz") ||
      parentHtml.includes("personaliz") ||
      html.includes("upload") ||
      parentHtml.includes("upload") ||
      html.includes("preview") ||
      parentHtml.includes("preview") ||
      html.includes("review") ||
      parentHtml.includes("review")
    );
  }

  function findCustomilyPreviewButton() {
    const allClickable = Array.from(document.querySelectorAll(
      "button, a, input[type='button'], input[type='submit'], [role='button']"
    ));

    const words = [
      "review",
      "preview",
      "prévisualiser",
      "previsualiser",
      "view preview",
      "see preview"
    ];

    let candidates = allClickable.filter(function (el) {
      if (!el || el.id === "hapyco-customily-preview-btn") return false;

      const text = getElementText(el);
      const hasPreviewWord = words.some(function (word) {
        return text.includes(word);
      });

      return hasPreviewWord && elementLooksCustomily(el);
    });

    if (!candidates.length) {
      candidates = allClickable.filter(function (el) {
        if (!el || el.id === "hapyco-customily-preview-btn") return false;

        const text = getElementText(el);

        return words.some(function (word) {
          return text.includes(word);
        });
      });
    }

    const visible = candidates.find(isVisibleEnough);
    return visible || candidates[0] || null;
  }

  function findCustomilyArea() {
    const candidates = Array.from(document.querySelectorAll(
      "[class*='customily'], [id*='customily'], [class*='personaliz'], [id*='personaliz'], form, .product-form"
    ));

    return candidates.find(function (el) {
      const html = normalizeText(el.outerHTML || "");
      return (
        html.includes("customily") ||
        html.includes("upload") ||
        html.includes("review") ||
        html.includes("preview")
      );
    }) || document.body;
  }

  function unlockPreviewWithoutTouchingImage() {
    const area = findCustomilyArea();

    const fields = Array.from(area.querySelectorAll(
      "input, select, textarea, button, a, [role='button']"
    ));

    fields.forEach(function (el) {
      if (!el) return;

      /*
        Important :
        On ne touche pas au champ upload image.
        On déverrouille seulement les autres options pour éviter
        que Customily attende tout avant d’ouvrir le preview.
      */
      if (el.tagName === "INPUT" && el.type === "file") return;

      el.removeAttribute("required");
      el.removeAttribute("aria-required");
      el.removeAttribute("disabled");
      el.removeAttribute("aria-disabled");

      if ("disabled" in el) {
        el.disabled = false;
      }

      el.style.pointerEvents = "auto";
      el.style.opacity = "1";

      el.classList.remove("disabled");
      el.classList.remove("is-disabled");
      el.classList.remove("customily-disabled");
    });

    const previewBtn = findCustomilyPreviewButton();

    if (previewBtn) {
      previewBtn.removeAttribute("disabled");
      previewBtn.removeAttribute("aria-disabled");

      if ("disabled" in previewBtn) {
        previewBtn.disabled = false;
      }

      previewBtn.style.pointerEvents = "auto";
      previewBtn.style.opacity = "1";

      previewBtn.classList.remove("disabled");
      previewBtn.classList.remove("is-disabled");
    }
  }

  function createStickyButton() {
    if (document.getElementById("hapyco-customily-preview-btn")) return;

    const btn = document.createElement("button");
    btn.id = "hapyco-customily-preview-btn";
    btn.type = "button";
    btn.textContent = SETTINGS.stickyButtonText;

    document.body.appendChild(btn);

    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();

      openCustomilyPreview();

      return false;
    });
  }

  function showStickyButton() {
    const btn = document.getElementById("hapyco-customily-preview-btn");

    if (btn) {
      btn.classList.add("is-visible");
      document.body.classList.add("hapyco-preview-active-padding");
    }
  }

  function openCustomilyPreview() {
    saveScroll();
    unlockPreviewWithoutTouchingImage();

    const realCustomilyBtn = findCustomilyPreviewButton();

    if (!realCustomilyBtn) {
      log("HAPYCO: Customily preview/review button not found.");
      protectScroll();
      return;
    }

    unlockPreviewWithoutTouchingImage();

    setTimeout(function () {
      realCustomilyBtn.click();
      protectScroll();
    }, 80);
  }

  function isImageUploadInput(el) {
    return (
      el &&
      el.tagName === "INPUT" &&
      el.type === "file" &&
      el.files &&
      el.files.length > 0
    );
  }

  function isOptionChange(el) {
    if (!el) return false;

    const html = normalizeText(el.outerHTML || "");
    const parent = el.closest("div, label, button, section, form");
    const parentHtml = parent ? normalizeText(parent.outerHTML || "") : "";

    return (
      elementLooksCustomily(el) ||
      html.includes("color") ||
      parentHtml.includes("color") ||
      html.includes("swatch") ||
      parentHtml.includes("swatch") ||
      html.includes("variant") ||
      parentHtml.includes("variant") ||
      html.includes("option") ||
      parentHtml.includes("option") ||
      el.matches("select, textarea, input[type='radio'], input[type='checkbox']")
    );
  }

  function handleImageUpload() {
    hasImageUploaded = true;
    saveScroll();
    showStickyButton();

    unlockPreviewWithoutTouchingImage();

    if (!SETTINGS.autoOpenAfterImageUpload) {
      protectScroll();
      return;
    }

    clearTimeout(refreshTimer);

    refreshTimer = setTimeout(function () {
      openCustomilyPreview();
    }, SETTINGS.imageUploadDelay);
  }

  function handleOptionChange() {
    if (!hasImageUploaded) return;

    saveScroll();
    showStickyButton();
    unlockPreviewWithoutTouchingImage();

    if (!SETTINGS.autoRefreshAfterOptionChange) {
      protectScroll();
      return;
    }

    clearTimeout(refreshTimer);

    refreshTimer = setTimeout(function () {
      openCustomilyPreview();
    }, SETTINGS.optionRefreshDelay);
  }

  function init() {
    createStickyButton();

    const observer = new MutationObserver(function () {
      if (hasImageUploaded) {
        unlockPreviewWithoutTouchingImage();
        showStickyButton();
      }
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ["disabled", "aria-disabled", "required", "class", "style"]
    });

    document.addEventListener("change", function (e) {
      const target = e.target;

      if (isImageUploadInput(target)) {
        handleImageUpload();
        return;
      }

      if (isOptionChange(target)) {
        handleOptionChange();
      }
    }, true);

    document.addEventListener("input", function (e) {
      if (isOptionChange(e.target)) {
        handleOptionChange();
      }
    }, true);

    document.addEventListener("click", function (e) {
      const target = e.target;

      if (!target || target.id === "hapyco-customily-preview-btn") return;

      if (isOptionChange(target)) {
        setTimeout(handleOptionChange, 250);
      }
    }, true);

    /*
      Sécurité scroll : si GemPages ou Customily fait un jump haut
      après une interaction, on corrige sans casser le scroll normal.
    */
    document.addEventListener("touchstart", function () {
      saveScroll();
    }, { passive: true });

    setInterval(function () {
      if (hasImageUploaded) {
        unlockPreviewWithoutTouchingImage();
        showStickyButton();
      }
    }, 1200);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
