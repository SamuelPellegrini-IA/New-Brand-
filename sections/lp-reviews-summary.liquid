{%- liquid
  assign avg = section.settings.average_rating | times: 1.0
  assign avg_pct = avg | divided_by: 5.0 | times: 100
  assign uid = section.id
-%}

{%- style -%}
  .lp-reviews-{{ uid }} {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .lp-reviews-{{ uid }} .lp-rv-wrap {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .lp-reviews-{{ uid }} .lp-rv-title {
    text-align: center;
    margin: 0 0 2.4rem;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.2;
  }
  .lp-reviews-{{ uid }} .lp-rv-summary {
    display: grid;
    grid-template-columns: minmax(160px, 0.6fr) 1.4fr;
    gap: 3.2rem;
    align-items: center;
    padding: 2.4rem;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 14px;
    margin-bottom: 3.2rem;
  }
  .lp-reviews-{{ uid }} .lp-rv-avg { text-align: center; }
  .lp-reviews-{{ uid }} .lp-rv-avg-num {
    font-size: 4.8rem;
    font-weight: 700;
    line-height: 1;
  }
  .lp-reviews-{{ uid }} .lp-rv-total { font-size: 1.4rem; opacity: .75; margin-top: .6rem; }
  .lp-stars {
    --p: 0%;
    display: inline-block;
    position: relative;
    font-size: 1.8rem;
    line-height: 1;
    letter-spacing: 2px;
    font-family: Arial, sans-serif;
  }
  .lp-stars::before { content: "★★★★★"; color: {{ section.settings.track_color }}; }
  .lp-stars::after {
    content: "★★★★★";
    color: {{ section.settings.star_color }};
    position: absolute;
    inset: 0;
    width: var(--p);
    overflow: hidden;
    white-space: nowrap;
  }
  .lp-reviews-{{ uid }} .lp-rv-bars { display: grid; gap: .8rem; }
  .lp-reviews-{{ uid }} .lp-rv-bar { display: grid; grid-template-columns: 34px 1fr auto; gap: 1rem; align-items: center; font-size: 1.3rem; }
  .lp-reviews-{{ uid }} .lp-rv-bar-label { display: flex; align-items: center; gap: 3px; white-space: nowrap; }
  .lp-reviews-{{ uid }} .lp-rv-bar-label span { color: {{ section.settings.star_color }}; }
  .lp-reviews-{{ uid }} .lp-rv-bar-track { height: 9px; border-radius: 30px; background: {{ section.settings.track_color }}; overflow: hidden; }
  .lp-reviews-{{ uid }} .lp-rv-bar-fill { height: 100%; border-radius: 30px; background: {{ section.settings.bar_color }}; }
  .lp-reviews-{{ uid }} .lp-rv-bar-count { font-size: 1.2rem; opacity: .7; min-width: 34px; text-align: right; }
  .lp-reviews-{{ uid }} .lp-rv-write { text-align: center; margin-bottom: 2.8rem; }
  .lp-reviews-{{ uid }} .lp-rv-list {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 1.6rem;
  }
  .lp-reviews-{{ uid }} .lp-rv-card {
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 12px;
    padding: 2rem;
  }
  .lp-reviews-{{ uid }} .lp-rv-card-head { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .lp-reviews-{{ uid }} .lp-rv-card-avatar { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
  .lp-reviews-{{ uid }} .lp-rv-card-avatar--ph { display: grid; place-items: center; background: {{ section.settings.bar_color }}; color: #fff; font-weight: 700; font-size: 1.6rem; }
  .lp-reviews-{{ uid }} .lp-rv-card-author { font-weight: 700; font-size: 1.4rem; }
  .lp-reviews-{{ uid }} .lp-rv-card-meta { font-size: 1.2rem; opacity: .65; }
  .lp-reviews-{{ uid }} .lp-rv-card-title { font-weight: 700; margin: .6rem 0 .4rem; font-size: 1.5rem; }
  .lp-reviews-{{ uid }} .lp-rv-card-text { font-size: 1.4rem; line-height: 1.55; }
  .lp-reviews-{{ uid }} .lp-rv-verified { display: inline-block; margin-top: 1rem; font-size: 1.1rem; color: #0a7d28; font-weight: 600; }
  @media screen and (max-width: 749px) {
    .lp-reviews-{{ uid }} .lp-rv-summary { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
    .lp-reviews-{{ uid }} .lp-rv-list { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<div class="lp-reviews-{{ uid }}">
  <div class="lp-rv-wrap">
    {%- if section.settings.heading != blank -%}
      <h2 class="lp-rv-title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="lp-rv-summary">
      <div class="lp-rv-avg">
        <div class="lp-rv-avg-num">{{ section.settings.average_rating }}</div>
        <div class="lp-stars" style="--p: {{ avg_pct }}%;" role="img" aria-label="{{ section.settings.average_rating }} / 5"></div>
        <div class="lp-rv-total">{{ section.settings.total_label }}</div>
      </div>
      <div class="lp-rv-bars">
        {%- for i in (1..5) reversed -%}
          {%- liquid
            assign pct_key = 'pct_' | append: i
            assign cnt_key = 'count_' | append: i
            assign pct = section.settings[pct_key]
            assign cnt = section.settings[cnt_key]
          -%}
          <div class="lp-rv-bar">
            <div class="lp-rv-bar-label">{{ i }}<span>★</span></div>
            <div class="lp-rv-bar-track"><div class="lp-rv-bar-fill" style="width: {{ pct }}%;"></div></div>
            <div class="lp-rv-bar-count">{% if section.settings.show_counts %}{{ cnt }}{% else %}{{ pct }}%{% endif %}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.show_write_button -%}
      <div class="lp-rv-write">
        <a class="button" href="{{ section.settings.write_button_link | default: '#' }}">{{ section.settings.write_button_label }}</a>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="lp-rv-list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign r = block.settings.rating | times: 1.0
            assign r_pct = r | divided_by: 5.0 | times: 100
          -%}
          <div class="lp-rv-card" {{ block.shopify_attributes }}>
            <div class="lp-rv-card-head">
              {%- if block.settings.image != blank -%}
                <img class="lp-rv-card-avatar" src="{{ block.settings.image | image_url: width: 84 }}" alt="{{ block.settings.author | escape }}" width="42" height="42" loading="lazy">
              {%- else -%}
                <div class="lp-rv-card-avatar lp-rv-card-avatar--ph">{{ block.settings.author | strip | slice: 0 | upcase }}</div>
              {%- endif -%}
              <div>
                <div class="lp-rv-card-author">{{ block.settings.author }}</div>
                {%- if block.settings.date != blank -%}<div class="lp-rv-card-meta">{{ block.settings.date }}</div>{%- endif -%}
              </div>
            </div>
            <div class="lp-stars" style="--p: {{ r_pct }}%; font-size: 1.5rem;" role="img" aria-label="{{ block.settings.rating }} / 5"></div>
            {%- if block.settings.title != blank -%}<div class="lp-rv-card-title">{{ block.settings.title }}</div>{%- endif -%}
            <div class="lp-rv-card-text">{{ block.settings.content }}</div>
            {%- if block.settings.verified -%}<span class="lp-rv-verified">✓ {{ block.settings.verified_label }}</span>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Avis clients (résumé)",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Customer Reviews" },
    { "type": "range", "id": "heading_size", "min": 20, "max": 56, "step": 1, "unit": "px", "label": "Taille du titre", "default": 32 },
    { "type": "header", "content": "Résumé de la note" },
    { "type": "text", "id": "average_rating", "label": "Note moyenne (sur 5)", "default": "4.8" },
    { "type": "text", "id": "total_label", "label": "Texte total", "default": "Based on 40 reviews" },
    { "type": "color", "id": "star_color", "label": "Couleur des étoiles", "default": "#ffce31" },
    { "type": "color", "id": "bar_color", "label": "Couleur des barres", "default": "#1a1a1a" },
    { "type": "color", "id": "track_color", "label": "Couleur de fond des barres", "default": "#ececec" },
    { "type": "header", "content": "Répartition des notes" },
    { "type": "checkbox", "id": "show_counts", "label": "Afficher le nombre (au lieu du %)", "default": false },
    { "type": "range", "id": "pct_5", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "5 étoiles", "default": 88 },
    { "type": "text", "id": "count_5", "label": "Nombre (5 étoiles)", "default": "35" },
    { "type": "range", "id": "pct_4", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "4 étoiles", "default": 8 },
    { "type": "text", "id": "count_4", "label": "Nombre (4 étoiles)", "default": "3" },
    { "type": "range", "id": "pct_3", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "3 étoiles", "default": 5 },
    { "type": "text", "id": "count_3", "label": "Nombre (3 étoiles)", "default": "2" },
    { "type": "range", "id": "pct_2", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "2 étoiles", "default": 0 },
    { "type": "text", "id": "count_2", "label": "Nombre (2 étoiles)", "default": "0" },
    { "type": "range", "id": "pct_1", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "1 étoile", "default": 0 },
    { "type": "text", "id": "count_1", "label": "Nombre (1 étoile)", "default": "0" },
    { "type": "header", "content": "Bouton" },
    { "type": "checkbox", "id": "show_write_button", "label": "Afficher le bouton", "default": true },
    { "type": "text", "id": "write_button_label", "label": "Texte du bouton", "default": "Write a review" },
    { "type": "url", "id": "write_button_link", "label": "Lien du bouton" },
    { "type": "header", "content": "Liste des avis" },
    { "type": "range", "id": "columns", "min": 1, "max": 3, "step": 1, "label": "Colonnes (desktop)", "default": 1 },
    { "type": "header", "content": "Apparence" },
    { "type": "color", "id": "background", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Texte", "default": "#121212" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Marge haut", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Marge bas", "default": 40 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis",
      "settings": [
        { "type": "text", "id": "author", "label": "Auteur", "default": "John D." },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Note", "default": 5 },
        { "type": "text", "id": "title", "label": "Titre de l'avis", "default": "Great product" },
        { "type": "richtext", "id": "content", "label": "Texte de l'avis", "default": "<p>Exactly what I expected. Great quality and fast delivery. Highly recommend!</p>" },
        { "type": "text", "id": "date", "label": "Date" },
        { "type": "image_picker", "id": "image", "label": "Photo de l'auteur (optionnel)" },
        { "type": "checkbox", "id": "verified", "label": "Acheteur vérifié", "default": true },
        { "type": "text", "id": "verified_label", "label": "Label vérifié", "default": "Verified buyer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avis clients (résumé)",
      "blocks": [
        { "type": "review", "settings": { "author": "David E.", "rating": 5, "title": "Shocking quality", "content": "<p>It is rare to find a company that delivers exactly what you ordered. The item came in a timely manner and was exactly as pictured.</p>" } },
        { "type": "review", "settings": { "author": "Liz C.", "rating": 5, "title": "Amazing", "content": "<p>This exceeded all my expectations! Good quality, fits well and the print is better than I ever expected.</p>" } },
        { "type": "review", "settings": { "author": "V. Arnold", "rating": 4, "title": "Love it", "content": "<p>Wonderful. My only suggestion is to order your normal size. Beautiful work.</p>" } }
      ]
    }
  ]
}
{% endschema %}
