{%- comment -%}
  Home · CTA banner
  Full-width call-to-action with an optional background image (add from Shopify),
  heading, text and a button. Overlay keeps text readable over any photo.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .home-cta {
    position: relative; overflow: hidden;
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .home-cta__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  #shopify-section-{{ section.id }} .home-cta__overlay { position: absolute; inset: 0; z-index: 1; background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; }
  #shopify-section-{{ section.id }} .home-cta__inner {
    position: relative; z-index: 2; max-width: 760px; margin: 0 auto; text-align: center;
    padding: {{ section.settings.padding_top | times: 0.6 | round: 0 }}px 20px {{ section.settings.padding_bottom | times: 0.6 | round: 0 }}px;
  }
  #shopify-section-{{ section.id }} .home-cta__title { font-size: clamp(28px, 4.5vw, 46px); line-height: 1.1; font-weight: 800; margin: 0 0 16px; }
  #shopify-section-{{ section.id }} .home-cta__text { font-size: 18px; line-height: 1.55; margin: 0 0 28px; opacity: .92; }
  #shopify-section-{{ section.id }} .home-cta__btn {
    display: inline-flex; align-items: center; justify-content: center; padding: 16px 38px;
    border-radius: 999px; font-weight: 700; font-size: 17px; text-decoration: none;
    background: {{ section.settings.accent_color }}; color: {{ section.settings.btn_text_color }};
    transition: transform .15s ease;
  }
  #shopify-section-{{ section.id }} .home-cta__btn:hover { transform: translateY(-2px); }
  #shopify-section-{{ section.id }} .home-cta__sub { margin: 16px 0 0; font-size: 14px; opacity: .8; }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .home-cta__inner { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  }
{%- endstyle -%}

<div class="home-cta">
  {%- if section.settings.background_image != blank -%}
    {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'home-cta__bg', widths: '800, 1200, 1600, 2000', sizes: '100vw' }}
    <div class="home-cta__overlay"></div>
  {%- endif -%}
  <div class="home-cta__inner">
    {%- if section.settings.heading != blank -%}<h2 class="home-cta__title">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.text != blank -%}<div class="home-cta__text">{{ section.settings.text }}</div>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="home-cta__btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}<p class="home-cta__sub">{{ section.settings.subtext }}</p>{%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Home · CTA banner",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to create yours?" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Upload a photo and design a shirt as unique as your best friend.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Personalize my shirt" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "subtext", "label": "Small text under button", "default": "45-day money-back guarantee · Free returns" },
    { "type": "header", "content": "Colors & overlay" },
    { "type": "color", "id": "bg_color", "label": "Background (no image)", "default": "#0f7a6b" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Button", "default": "#ffce31" },
    { "type": "color", "id": "btn_text_color", "label": "Button text", "default": "#1a1a1a" },
    { "type": "color", "id": "overlay_color", "label": "Image overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 40 },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 2, "unit": "px", "default": 110 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 2, "unit": "px", "default": 110 }
  ],
  "presets": [ { "name": "Home · CTA banner" } ]
}
{% endschema %}
