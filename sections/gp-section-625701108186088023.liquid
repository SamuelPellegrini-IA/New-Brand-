      <div>
    <style>
@media only screen and (max-width: 768px) {
  #hapyco-customily-preview-mobile {
    position: fixed !important;
    left: 14px !important;
    right: 14px !important;
    bottom: 14px !important;
    z-index: 9999999 !important;

    display: none !important;
    align-items: center !important;
    justify-content: center !important;

    background: #FFD814 !important;
    color: #111 !important;
    border: 1px solid #e0bd00 !important;
    border-radius: 12px !important;

    padding: 15px 18px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
    text-align: center !important;

    box-shadow: 0 8px 22px rgba(0,0,0,0.20) !important;
    cursor: pointer !important;
  }

  #hapyco-customily-preview-mobile.is-visible {
    display: flex !important;
  }

  body.hapyco-preview-padding {
    padding-bottom: 82px !important;
  }
}
</style>

<script>
(function () {
  if (window.innerWidth > 768) return;

  let imageUploaded = false;
  let lastStableScrollY = 0;
  let scrollProtectionActive = false;

  function getScrollY() {
    return window.scrollY || document.documentElement.scrollTop || 0;
  }

  function saveScrollPosition() {
    lastStableScrollY = getScrollY();
  }

  function protectScrollForShortTime() {
    const targetY = lastStableScrollY;
    scrollProtectionActive = true;

    const checks = [60, 160, 320, 650, 1000];

    checks.forEach(function (delay) {
      setTimeout(function () {
        const currentY = getScrollY();

        /*
          On corrige seulement si Customily/GemPages remonte vers le haut.
          Si le client scroll normalement vers le bas, on ne bloque pas.
        */
        if (scrollProtectionActive && currentY < targetY - 120) {
          window.scrollTo({
            top: targetY,
            left: 0,
            behavior: "auto"
          });
        }
      }, delay);
    });

    setTimeout(function () {
      scrollProtectionActive = false;
    }, 1200);
  }

  function getText(el) {
    return (
      el.innerText ||
      el.textContent ||
      el.value ||
      el.getAttribute("aria-label") ||
      el.getAttribute("title") ||
      ""
    ).trim().toLowerCase();
  }

  function isVisible(el) {
    if (!el) return false;

    const rect = el.getBoundingClientRect();
    const style = window.getComputedStyle(el);

    return (
      rect.width > 0 &&
      rect.height > 0 &&
      style.display !== "none" &&
      style.visibility !== "hidden" &&
      style.opacity !== "0"
    );
  }

  function looksLikeCustomily(el) {
    if (!el) return false;

    const html = (el.outerHTML || "").toLowerCase();
    const parent = el.closest("div, section, form, product-form");
    const parentHtml = parent ? (parent.outerHTML || "").toLowerCase() : "";

    return (
      html.includes("customily") ||
      parentHtml.includes("customily") ||
      html.includes("personaliz") ||
      parentHtml.includes("personaliz") ||
      html.includes("upload") ||
      parentHtml.includes("upload") ||
      html.includes("review") ||
      parentHtml.includes("review") ||
      html.includes("preview") ||
      parentHtml.includes("preview")
    );
  }

  function findCustomilyReviewButton() {
    const allButtons = Array.from(document.querySelectorAll(
      'button, a, input[type="button"], input[type="submit"], [role="button"]'
    ));

    const reviewWords = [
      "review",
      "preview",
      "prévisualiser",
      "previsualiser",
      "view preview",
      "see preview"
    ];

    const customilyButtons = allButtons.filter(function (el) {
      if (!el || el.id === "hapyco-customily-preview-mobile") return false;

      const text = getText(el);
      const hasReviewText = reviewWords.some(function (word) {
        return text.includes(word);
      });

      return hasReviewText && looksLikeCustomily(el);
    });

    if (customilyButtons.length) {
      return customilyButtons[0];
    }

    const fallbackButtons = allButtons.filter(function (el) {
      if (!el || el.id === "hapyco-customily-preview-mobile") return false;

      const text = getText(el);

      return reviewWords.some(function (word) {
        return text.includes(word);
      });
    });

    return fallbackButtons[0] || null;
  }

  function forceUnlockCustomilyPreview() {
    /*
      Important :
      On ne touche pas au fichier image.
      On enlève seulement les blocages front sur les autres champs,
      pour que Customily laisse ouvrir le preview après l’upload image.
    */

    const customilyFields = Array.from(document.querySelectorAll(
      'input, select, textarea, button, a, [role="button"]'
    )).filter(function (el) {
      return looksLikeCustomily(el);
    });

    customilyFields.forEach(function (el) {
      if (el.tagName === "INPUT" && el.type === "file") return;

      el.removeAttribute("required");
      el.removeAttribute("aria-required");
      el.removeAttribute("disabled");
      el.removeAttribute("aria-disabled");

      if ("disabled" in el) {
        el.disabled = false;
      }

      el.style.pointerEvents = "auto";
      el.style.opacity = "1";

      el.classList.remove("disabled");
      el.classList.remove("is-disabled");
      el.classList.remove("customily-disabled");
    });

    const reviewBtn = findCustomilyReviewButton();

    if (reviewBtn) {
      reviewBtn.removeAttribute("disabled");
      reviewBtn.removeAttribute("aria-disabled");

      if ("disabled" in reviewBtn) {
        reviewBtn.disabled = false;
      }

      reviewBtn.style.pointerEvents = "auto";
      reviewBtn.style.opacity = "1";
      reviewBtn.classList.remove("disabled");
      reviewBtn.classList.remove("is-disabled");
    }
  }

  function createMobilePreviewButton() {
    if (document.getElementById("hapyco-customily-preview-mobile")) return;

    const btn = document.createElement("button");
    btn.id = "hapyco-customily-preview-mobile";
    btn.type = "button";
    btn.textContent = "Preview Your Design";

    document.body.appendChild(btn);
    document.body.classList.add("hapyco-preview-padding");

    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();

      saveScrollPosition();
      forceUnlockCustomilyPreview();

      const reviewBtn = findCustomilyReviewButton();

      if (!reviewBtn) {
        console.warn("HAPYCO: Customily Preview / Review button not found.");
        return false;
      }

      forceUnlockCustomilyPreview();

      setTimeout(function () {
        reviewBtn.click();
        protectScrollForShortTime();
      }, 80);

      return false;
    });
  }

  function showMobilePreviewButton() {
    const btn = document.getElementById("hapyco-customily-preview-mobile");
    if (btn) {
      btn.classList.add("is-visible");
    }
  }

  function isImageUploadInput(el) {
    return (
      el &&
      el.tagName === "INPUT" &&
      el.type === "file" &&
      el.files &&
      el.files.length > 0
    );
  }

  function isCustomilyOption(el) {
    if (!el) return false;

    const html = (el.outerHTML || "").toLowerCase();
    const parent = el.closest("div, label, button, section, form");
    const parentHtml = parent ? (parent.outerHTML || "").toLowerCase() : "";

    return (
      looksLikeCustomily(el) ||
      html.includes("color") ||
      parentHtml.includes("color") ||
      html.includes("swatch") ||
      parentHtml.includes("swatch") ||
      html.includes("variant") ||
      parentHtml.includes("variant") ||
      el.matches("select, input[type='radio'], input[type='checkbox'], textarea")
    );
  }

  function openPreviewAfterImageUpload() {
    saveScrollPosition();
    forceUnlockCustomilyPreview();
    showMobilePreviewButton();

    /*
      On laisse Customily finir l’upload / processing de l’image.
      Ensuite seulement on ouvre le vrai preview.
    */
    setTimeout(function () {
      forceUnlockCustomilyPreview();

      const reviewBtn = findCustomilyReviewButton();

      if (reviewBtn) {
        reviewBtn.click();
        protectScrollForShortTime();
      }
    }, 900);
  }

  function updatePreviewAfterOptionChange() {
    if (!imageUploaded) return;

    saveScrollPosition();
    forceUnlockCustomilyPreview();

    /*
      Ne force pas une nouvelle image.
      Ça demande juste à Customily de refresh son vrai preview.
    */
    setTimeout(function () {
      forceUnlockCustomilyPreview();

      const reviewBtn = findCustomilyReviewButton();

      if (reviewBtn) {
        reviewBtn.click();
        protectScrollForShortTime();
      }
    }, 350);
  }

  document.addEventListener("DOMContentLoaded", function () {
    createMobilePreviewButton();

    /*
      MutationObserver pour déverrouiller le bouton preview
      quand Customily recharge ses éléments.
    */
    const observer = new MutationObserver(function () {
      if (imageUploaded) {
        forceUnlockCustomilyPreview();
        showMobilePreviewButton();
      }
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ["disabled", "aria-disabled", "class"]
    });

    document.addEventListener("change", function (e) {
      const target = e.target;

      if (isImageUploadInput(target)) {
        imageUploaded = true;
        openPreviewAfterImageUpload();
        return;
      }

      if (imageUploaded && isCustomilyOption(target)) {
        updatePreviewAfterOptionChange();
      }
    }, true);

    document.addEventListener("input", function (e) {
      if (imageUploaded && isCustomilyOption(e.target)) {
        updatePreviewAfterOptionChange();
      }
    }, true);

    document.addEventListener("click", function (e) {
      const target = e.target;

      if (!target || target.id === "hapyco-customily-preview-mobile") return;

      if (imageUploaded && isCustomilyOption(target)) {
        setTimeout(function () {
          updatePreviewAfterOptionChange();
        }, 250);
      }
    }, true);

    /*
      Sécurité : si Customily désactive le bouton après upload,
      on le réactive sans faire bouger la page.
    */
    setInterval(function () {
      if (imageUploaded) {
        forceUnlockCustomilyPreview();
        showMobilePreviewButton();
      }
    }, 900);
  });
})();
</script>
    </div>
    </div>
  
