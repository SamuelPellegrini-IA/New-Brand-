</style>

<script>
(function () {
  if (window.__hapycoMobilePreviewLoaded) return;
  window.__hapycoMobilePreviewLoaded = true;

  let personalizationStarted = false;

  function isMobile() {
    return window.matchMedia('(max-width: 768px)').matches;
  }

  function showPreviewButton() {
    if (!isMobile()) return;

    personalizationStarted = true;
    document.body.classList.add('hapyco-preview-active');

    const btn = document.getElementById('hapyco-mobile-preview-btn');
    if (btn) btn.classList.add('hapyco-show');
  }

  function findNativePreviewButton() {
    const elements = Array.from(document.querySelectorAll(
      'button, a, input[type="button"], input[type="submit"], div[role="button"]'
    ));

    return elements.find(function (el) {
      if (el.id === 'hapyco-mobile-preview-btn') return false;

      const text = (
        el.innerText ||
        el.value ||
        el.getAttribute('aria-label') ||
        ''
      ).toLowerCase();

      const cls = (el.className || '').toString().toLowerCase();
      const id = (el.id || '').toLowerCase();

      return (
        (
          text.includes('preview') ||
          text.includes('personalization') ||
          text.includes('preview your personalization') ||
          cls.includes('preview') ||
          id.includes('preview')
        ) &&
        !text.includes('help') &&
        !text.includes('cart') &&
        !text.includes('checkout')
      );
    });
  }

  function findPreviewArea() {
    return (
      document.querySelector('[class*="preview"]') ||
      document.querySelector('[id*="preview"]') ||
      document.querySelector('.product__media-wrapper') ||
      document.querySelector('.product-media') ||
      document.querySelector('.product-gallery') ||
      document.querySelector('[class*="gallery"]') ||
      document.querySelector('[class*="media"]')
    );
  }

  function scrollToPreview() {
    setTimeout(function () {
      const previewArea = findPreviewArea();

      if (previewArea) {
        previewArea.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      } else {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      }
    }, 600);
  }

  function temporarilyDisableRequiredFields() {
    const fields = document.querySelectorAll(
      'input[required], select[required], textarea[required], [aria-required="true"]'
    );

    fields.forEach(function (field) {
      if (field.hasAttribute('required')) {
        field.setAttribute('data-hapyco-required', 'true');
        field.removeAttribute('required');
      }

      if (field.getAttribute('aria-required') === 'true') {
        field.setAttribute('data-hapyco-aria-required', 'true');
        field.setAttribute('aria-required', 'false');
      }
    });
  }

  function restoreRequiredFields() {
    const fields = document.querySelectorAll('[data-hapyco-required], [data-hapyco-aria-required]');

    fields.forEach(function (field) {
      if (field.getAttribute('data-hapyco-required') === 'true') {
        field.setAttribute('required', 'required');
        field.removeAttribute('data-hapyco-required');
      }

      if (field.getAttribute('data-hapyco-aria-required') === 'true') {
        field.setAttribute('aria-required', 'true');
        field.removeAttribute('data-hapyco-aria-required');
      }
    });
  }

  function unlockDisabledPreviewButton(nativePreviewBtn) {
    if (!nativePreviewBtn) return;

    if (nativePreviewBtn.disabled) {
      nativePreviewBtn.setAttribute('data-hapyco-was-disabled', 'true');
      nativePreviewBtn.disabled = false;
    }

    if (nativePreviewBtn.getAttribute('aria-disabled') === 'true') {
      nativePreviewBtn.setAttribute('data-hapyco-was-aria-disabled', 'true');
      nativePreviewBtn.setAttribute('aria-disabled', 'false');
    }

    nativePreviewBtn.style.pointerEvents = 'auto';
  }

  function restorePreviewButton(nativePreviewBtn) {
    if (!nativePreviewBtn) return;

    if (nativePreviewBtn.getAttribute('data-hapyco-was-disabled') === 'true') {
      nativePreviewBtn.disabled = true;
      nativePreviewBtn.removeAttribute('data-hapyco-was-disabled');
    }

    if (nativePreviewBtn.getAttribute('data-hapyco-was-aria-disabled') === 'true') {
      nativePreviewBtn.setAttribute('aria-disabled', 'true');
      nativePreviewBtn.removeAttribute('data-hapyco-was-aria-disabled');
    }
  }

  function clickPreviewWithoutFullValidation() {
    const nativePreviewBtn = findNativePreviewButton();

    temporarilyDisableRequiredFields();
    unlockDisabledPreviewButton(nativePreviewBtn);

    if (nativePreviewBtn) {
      nativePreviewBtn.click();
    }

    setTimeout(function () {
      restoreRequiredFields();
      restorePreviewButton(nativePreviewBtn);
    }, 1200);

    scrollToPreview();
  }

  function createMobileButton() {
    if (!isMobile()) return;
    if (document.getElementById('hapyco-mobile-preview-btn')) return;

    const btn = document.createElement('button');
    btn.id = 'hapyco-mobile-preview-btn';
    btn.type = 'button';
    btn.innerText = 'Preview Your Personalization';

    btn.addEventListener('click', function () {
      clickPreviewWithoutFullValidation();
    });

    document.body.appendChild(btn);

    if (personalizationStarted) {
      btn.classList.add('hapyco-show');
    }
  }

  function isPersonalizationAction(target) {
    if (!target) return false;

    const el = target.closest('button, a, input, select, label, div, span');
    if (!el) return false;

    const text = (
      el.innerText ||
      el.value ||
      el.getAttribute('aria-label') ||
      el.getAttribute('name') ||
      el.getAttribute('id') ||
      el.getAttribute('class') ||
      ''
    ).toLowerCase();

    const parentText = (
      el.closest('form, .product-form, [class*="product"], [class*="custom"], [class*="personal"]')?.innerText ||
      ''
    ).toLowerCase();

    if (el.matches('input[type="file"]')) return true;

    return (
      text.includes('select image') ||
      text.includes('upload') ||
      text.includes('photo') ||
      text.includes('background') ||
      text.includes('leave') ||
      text.includes('leaf') ||
      text.includes('color') ||
      parentText.includes('image upload') ||
      parentText.includes('number of photo') ||
      parentText.includes("background's color") ||
      parentText.includes("leave's color")
    );
  }

  function watchPersonalization() {
    document.addEventListener('click', function (e) {
      if (e.target.closest('#hapyco-mobile-preview-btn')) return;

      if (isPersonalizationAction(e.target)) {
        showPreviewButton();
      }
    }, true);

    document.addEventListener('change', function (e) {
      if (isPersonalizationAction(e.target)) {
        showPreviewButton();
      }
    }, true);

    document.addEventListener('input', function (e) {
      if (isPersonalizationAction(e.target)) {
        showPreviewButton();
      }
    }, true);
  }

  function init() {
    createMobileButton();
    watchPersonalization();

    const observer = new MutationObserver(function () {
      createMobileButton();
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  window.addEventListener('resize', createMobileButton);
})();
</script>
