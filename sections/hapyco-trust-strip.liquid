{%- liquid
  assign t1 = section.settings.text_1
  assign t2 = section.settings.text_2
-%}
<div class="hapyco-strip section-{{ section.id }}-padding" style="--strip-bg:{{ section.settings.bg_color }};--strip-text:{{ section.settings.text_color }};--strip-accent:{{ section.settings.accent_color }}">
  <div class="page-width hapyco-strip__inner">
    {%- if t1 != blank -%}
      <span class="hapyco-strip__item">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.4 8.5-8 11-4.6-2.5-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
        <span>{{ t1 }}</span>
      </span>
    {%- endif -%}
    {%- if t2 != blank -%}
      <span class="hapyco-strip__item">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/></svg>
        <span>{{ t2 }}</span>
      </span>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  .hapyco-strip { background: var(--strip-bg); color: var(--strip-text); font-family: Montserrat, -apple-system, sans-serif; }
  .hapyco-strip__inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 14px 34px; }
  .hapyco-strip__item { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; }
  .hapyco-strip__item svg { color: var(--strip-accent); flex: 0 0 auto; }
  @media (max-width: 749px){ .hapyco-strip__item { font-size: 11px; } }
{%- endstyle -%}

{% schema %}
{
  "name": "Hapyco · Trust strip",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "text_1", "label": "Texte 1", "default": "45-day money-back guarantee" },
    { "type": "text", "id": "text_2", "label": "Texte 2", "default": "Free returns, no questions asked" },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#f7f7f7" },
    { "type": "color", "id": "text_color", "label": "Texte", "default": "#121212" },
    { "type": "color", "id": "accent_color", "label": "Icônes", "default": "#00237e" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding haut", "default": 16 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding bas", "default": 16 }
  ],
  "presets": [{ "name": "Hapyco · Trust strip" }]
}
{% endschema %}
