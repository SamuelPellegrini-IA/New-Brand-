      <div>
    <style>
@media only screen and (max-width: 768px) {
  #hapyco-customily-preview-sticky {
    position: fixed !important;
    left: 14px !important;
    right: 14px !important;
    bottom: 14px !important;
    z-index: 9999999 !important;
    background: #FFD814 !important;
    color: #111 !important;
    border: 1px solid #e0bd00 !important;
    border-radius: 12px !important;
    padding: 15px 18px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
    text-align: center !important;
    box-shadow: 0 8px 22px rgba(0,0,0,0.20) !important;
    display: none !important;
    cursor: pointer !important;
  }

  #hapyco-customily-preview-sticky.is-visible {
    display: block !important;
  }

  body {
    padding-bottom: 82px !important;
  }
}
</style>

<script>
(function () {
  if (window.innerWidth > 768) return;

  let lastScrollY = 0;
  let imageUploaded = false;

  function saveScroll() {
    lastScrollY = window.scrollY || document.documentElement.scrollTop || 0;
  }

  function restoreScroll() {
    setTimeout(function () {
      window.scrollTo(0, lastScrollY);
    }, 80);

    setTimeout(function () {
      window.scrollTo(0, lastScrollY);
    }, 250);

    setTimeout(function () {
      window.scrollTo(0, lastScrollY);
    }, 600);
  }

  function createStickyPreviewButton() {
    if (document.getElementById("hapyco-customily-preview-sticky")) return;

    const btn = document.createElement("button");
    btn.id = "hapyco-customily-preview-sticky";
    btn.type = "button";
    btn.textContent = "Preview Your Design";

    document.body.appendChild(btn);

    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();

      openRealCustomilyPreview();

      return false;
    });
  }

  function showStickyPreviewButton() {
    const btn = document.getElementById("hapyco-customily-preview-sticky");
    if (btn) {
      btn.classList.add("is-visible");
    }
  }

  function getText(el) {
    return (
      el.innerText ||
      el.textContent ||
      el.value ||
      el.getAttribute("aria-label") ||
      el.getAttribute("title") ||
      ""
    ).trim().toLowerCase();
  }

  function looksLikeCustomily(el) {
    if (!el) return false;

    const html = (el.outerHTML || "").toLowerCase();
    const parent = el.closest("div, section, form");
    const parentHtml = parent ? (parent.outerHTML || "").toLowerCase() : "";

    return (
      html.includes("customily") ||
      parentHtml.includes("customily") ||
      html.includes("personaliz") ||
      parentHtml.includes("personaliz") ||
      html.includes("upload") ||
      parentHtml.includes("upload")
    );
  }

  function findCustomilyReviewButton() {
    const clickable = Array.from(document.querySelectorAll(
      'button, a, input[type="button"], input[type="submit"], [role="button"]'
    ));

    const reviewWords = [
      "review",
      "preview",
      "prévisualiser",
      "previsualiser",
      "view preview",
      "see preview"
    ];

    let candidates = clickable.filter(function (el) {
      if (!el || el.id === "hapyco-customily-preview-sticky") return false;

      const text = getText(el);
      if (!text) return false;

      const isReview = reviewWords.some(function (word) {
        return text.includes(word);
      });

      return isReview && looksLikeCustomily(el);
    });

    if (!candidates.length) {
      candidates = clickable.filter(function (el) {
        if (!el || el.id === "hapyco-customily-preview-sticky") return false;

        const text = getText(el);
        if (!text) return false;

        return reviewWords.some(function (word) {
          return text.includes(word);
        });
      });
    }

    return candidates[0] || null;
  }

  function temporarilyAllowPreview() {
    const changed = [];

    const fields = Array.from(document.querySelectorAll(
      'input, select, textarea, button'
    ));

    fields.forEach(function (el) {
      if (!looksLikeCustomily(el)) return;

      if (el.tagName === "INPUT" && el.type === "file") return;

      if (el.hasAttribute("required")) {
        changed.push({ el: el, attr: "required" });
        el.removeAttribute("required");
      }

      if (el.hasAttribute("aria-required")) {
        changed.push({ el: el, attr: "aria-required", value: el.getAttribute("aria-required") });
        el.removeAttribute("aria-required");
      }
    });

    return function restoreRequiredFields() {
      changed.forEach(function (item) {
        if (item.attr === "required") {
          item.el.setAttribute("required", "required");
        }

        if (item.attr === "aria-required") {
          item.el.setAttribute("aria-required", item.value || "true");
        }
      });
    };
  }

  function forceEnableButton(btn) {
    if (!btn) return;

    btn.disabled = false;
    btn.removeAttribute("disabled");
    btn.removeAttribute("aria-disabled");
    btn.style.pointerEvents = "auto";
    btn.style.opacity = "1";
    btn.classList.remove("disabled");
    btn.classList.remove("is-disabled");
  }

  function openRealCustomilyPreview() {
    saveScroll();

    const restoreRequired = temporarilyAllowPreview();
    const reviewBtn = findCustomilyReviewButton();

    if (!reviewBtn) {
      console.warn("HAPYCO: Customily preview/review button not found.");
      restoreScroll();
      return;
    }

    forceEnableButton(reviewBtn);

    setTimeout(function () {
      reviewBtn.click();
      restoreScroll();
    }, 80);

    setTimeout(function () {
      restoreRequired();
    }, 1200);
  }

  function isFileUploadWithImage(el) {
    return (
      el &&
      el.tagName === "INPUT" &&
      el.type === "file" &&
      el.files &&
      el.files.length > 0
    );
  }

  function isColorOrOptionChange(el) {
    if (!el) return false;

    const html = (el.outerHTML || "").toLowerCase();
    const parent = el.closest("div, label, button, section, form");
    const parentHtml = parent ? (parent.outerHTML || "").toLowerCase() : "";

    return (
      looksLikeCustomily(el) ||
      html.includes("color") ||
      parentHtml.includes("color") ||
      html.includes("swatch") ||
      parentHtml.includes("swatch") ||
      html.includes("variant") ||
      parentHtml.includes("variant") ||
      el.matches("select, input[type='radio'], input[type='checkbox']")
    );
  }

  function refreshPreviewAfterOptionChange() {
    if (!imageUploaded) return;

    saveScroll();

    const reviewBtn = findCustomilyReviewButton();

    if (reviewBtn) {
      forceEnableButton(reviewBtn);

      setTimeout(function () {
        reviewBtn.click();
        restoreScroll();
      }, 250);
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    createStickyPreviewButton();

    document.addEventListener("change", function (e) {
      const target = e.target;

      if (isFileUploadWithImage(target)) {
        imageUploaded = true;
        showStickyPreviewButton();

        setTimeout(function () {
          openRealCustomilyPreview();
        }, 700);

        return;
      }

      if (isColorOrOptionChange(target)) {
        refreshPreviewAfterOptionChange();
      }
    }, true);

    document.addEventListener("click", function (e) {
      const target = e.target;

      if (!target || target.id === "hapyco-customily-preview-sticky") return;

      if (isColorOrOptionChange(target)) {
        if (imageUploaded) {
          setTimeout(function () {
            refreshPreviewAfterOptionChange();
          }, 300);
        }
      }
    }, true);

    document.addEventListener("input", function (e) {
      if (imageUploaded && isColorOrOptionChange(e.target)) {
        refreshPreviewAfterOptionChange();
      }
    }, true);
  });
})();
</script>
