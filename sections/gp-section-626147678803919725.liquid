    <style>
@media only screen and (max-width: 768px) {
  #hapyco-customily-preview-safe {
    position: fixed !important;
    left: 14px !important;
    right: 14px !important;
    bottom: 14px !important;
    width: calc(100% - 28px) !important;
    z-index: 99999999 !important;

    display: none !important;
    align-items: center !important;
    justify-content: center !important;

    background: #FFD814 !important;
    color: #111 !important;
    border: 1px solid #e0bd00 !important;
    border-radius: 12px !important;

    padding: 15px 18px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
    text-align: center !important;

    box-shadow: 0 8px 22px rgba(0,0,0,0.22) !important;
    cursor: pointer !important;
    -webkit-tap-highlight-color: transparent !important;
  }

  #hapyco-customily-preview-safe.is-visible {
    display: flex !important;
  }

  body.hapyco-preview-padding {
    padding-bottom: 84px !important;
  }
}
</style>

<script>
(function () {
  if (window.innerWidth > 768) return;

  let imageUploaded = false;
  let lastScrollY = 0;

  function getScrollY() {
    return window.scrollY || document.documentElement.scrollTop || 0;
  }

  function saveScroll() {
    lastScrollY = getScrollY();
  }

  function restoreScrollIfJumped() {
    const targetY = lastScrollY;

    [100, 250, 500, 900].forEach(function (delay) {
      setTimeout(function () {
        const currentY = getScrollY();

        if (currentY < targetY - 120) {
          window.scrollTo({
            top: targetY,
            left: 0,
            behavior: "auto"
          });
        }
      }, delay);
    });
  }

  function createStickyButton() {
    if (document.getElementById("hapyco-customily-preview-safe")) return;

    const btn = document.createElement("button");
    btn.id = "hapyco-customily-preview-safe";
    btn.type = "button";
    btn.textContent = "Preview Your Design";

    document.body.appendChild(btn);

    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();

      saveScroll();

      const customilyBtn = findCustomilyPreviewButton();

      if (customilyBtn) {
        unlockButton(customilyBtn);
        customilyBtn.click();
        restoreScrollIfJumped();
      } else {
        console.warn("HAPYCO: Customily preview button not found.");
      }

      return false;
    });
  }

  function showStickyButton() {
    const btn = document.getElementById("hapyco-customily-preview-safe");

    if (btn) {
      btn.classList.add("is-visible");
      document.body.classList.add("hapyco-preview-padding");
    }
  }

  function normalizeText(text) {
    return String(text || "").trim().toLowerCase().replace(/\s+/g, " ");
  }

  function getText(el) {
    return normalizeText(
      el.innerText ||
      el.textContent ||
      el.value ||
      el.getAttribute("aria-label") ||
      el.getAttribute("title") ||
      ""
    );
  }

  function findCustomilyPreviewButton() {
    const buttons = Array.from(document.querySelectorAll(
      "button, a, input[type='button'], input[type='submit'], [role='button']"
    ));

    const previewWords = [
      "review",
      "preview",
      "prévisualiser",
      "previsualiser",
      "view preview",
      "see preview"
    ];

    const candidates = buttons.filter(function (el) {
      if (!el || el.id === "hapyco-customily-preview-safe") return false;

      const text = getText(el);

      return previewWords.some(function (word) {
        return text.includes(word);
      });
    });

    return candidates[0] || null;
  }

  function unlockButton(btn) {
    if (!btn) return;

    btn.removeAttribute("disabled");
    btn.removeAttribute("aria-disabled");

    if ("disabled" in btn) {
      btn.disabled = false;
    }

    btn.style.pointerEvents = "auto";
    btn.style.opacity = "1";
  }

  function isImageUploadInput(el) {
    return (
      el &&
      el.tagName === "INPUT" &&
      el.type === "file" &&
      el.files &&
      el.files.length > 0
    );
  }

  function isOptionElement(el) {
    if (!el) return false;

    const html = String(el.outerHTML || "").toLowerCase();
    const parent = el.closest("div, label, button, section, form");
    const parentHtml = parent ? String(parent.outerHTML || "").toLowerCase() : "";

    return (
      html.includes("customily") ||
      parentHtml.includes("customily") ||
      html.includes("color") ||
      parentHtml.includes("color") ||
      html.includes("swatch") ||
      parentHtml.includes("swatch") ||
      html.includes("option") ||
      parentHtml.includes("option") ||
      el.matches("select, input[type='radio'], input[type='checkbox'], textarea")
    );
  }

  function handleUploadDone() {
    imageUploaded = true;
    showStickyButton();

    /*
      Important :
      On ne lance PAS automatiquement le preview ici.
      Ça évite le freeze pendant l’upload Customily.
    */
  }

  function handleOptionChange() {
    if (!imageUploaded) return;

    saveScroll();
    showStickyButton();

    /*
      On ne reclique pas automatiquement sur Preview.
      Customily mettra à jour son propre preview quand le client l’ouvre.
      Ça évite les boucles et les freezes.
    */
    restoreScrollIfJumped();
  }

  function init() {
    createStickyButton();

    document.addEventListener("change", function (e) {
      const target = e.target;

      if (isImageUploadInput(target)) {
        handleUploadDone();
        return;
      }

      if (isOptionElement(target)) {
        handleOptionChange();
      }
    }, true);

    document.addEventListener("click", function (e) {
      const target = e.target;

      if (!target || target.id === "hapyco-customily-preview-safe") return;

      if (isOptionElement(target)) {
        handleOptionChange();
      }
    }, true);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
