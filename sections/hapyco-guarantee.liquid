{%- liquid
  assign blocks = section.blocks
-%}
<div class="hapyco-guarantee section-{{ section.id }}-padding" style="--g-bg:{{ section.settings.bg_color }};--g-text:{{ section.settings.text_color }};--g-accent:{{ section.settings.accent_color }};--g-card:{{ section.settings.card_color }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="hapyco-guarantee__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="hapyco-guarantee__grid">
      {%- for block in blocks -%}
        <div class="hapyco-guarantee__card" {{ block.shopify_attributes }}>
          <span class="hapyco-guarantee__icon">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'leaf' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 3C9 4 4 9 4 19c6-1 13-4 16-13"/><path d="M8 17c3-5 7-8 11-9"/></svg>
                {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 3v6c0 5-3.4 8.5-8 11-4.6-2.5-8-6-8-11V5z"/><path d="M9 12l2 2 4-4"/></svg>
                {%- when 'support' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14v-3a8 8 0 0 1 16 0v3"/><rect x="2.5" y="13.5" width="4" height="6" rx="1.5"/><rect x="17.5" y="13.5" width="4" height="6" rx="1.5"/></svg>
                {%- when 'lock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="18.5" cy="18.5" r="2"/></svg>
                {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12l2.5 2.5L16 9"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </span>
          {%- if block.settings.title != blank -%}<h3 class="hapyco-guarantee__title">{{ block.settings.title }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<p class="hapyco-guarantee__text">{{ block.settings.text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px; }
  @media (min-width:750px){ .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
  .hapyco-guarantee { background: var(--g-bg); color: var(--g-text); font-family: Montserrat, -apple-system, sans-serif; }
  .hapyco-guarantee__heading { text-align: center; font-size: clamp(22px,3vw,32px); font-weight: 800; margin: 0 0 28px; }
  .hapyco-guarantee__grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  .hapyco-guarantee__card { background: var(--g-card); border-radius: 14px; padding: 24px 20px; text-align: center; }
  .hapyco-guarantee__icon { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; color: var(--g-accent); margin-bottom: 12px; }
  .hapyco-guarantee__icon svg { width: 40px; height: 40px; }
  .hapyco-guarantee__icon img { width: 48px; height: 48px; object-fit: contain; }
  .hapyco-guarantee__title { font-size: 16px; font-weight: 700; margin: 0 0 8px; }
  .hapyco-guarantee__text { font-size: 14px; line-height: 1.5; opacity: .8; margin: 0; }
  @media (min-width:750px){ .hapyco-guarantee__grid { grid-template-columns: repeat(4, 1fr); gap: 20px; } }
{%- endstyle -%}

{% schema %}
{
  "name": "Hapyco · Guarantee",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "The BoxHero Guarantee" },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "card_color", "label": "Fond carte", "default": "#f7f7f7" },
    { "type": "color", "id": "text_color", "label": "Texte", "default": "#121212" },
    { "type": "color", "id": "accent_color", "label": "Icônes", "default": "#00237e" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding haut", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bas", "default": 48 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Garantie",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "default": "shield", "options": [
          { "value": "leaf", "label": "Feuille" }, { "value": "shield", "label": "Bouclier" }, { "value": "support", "label": "Support" }, { "value": "lock", "label": "Cadenas" }, { "value": "truck", "label": "Camion" }, { "value": "check", "label": "Coche" }
        ] },
        { "type": "image_picker", "id": "image", "label": "Image (remplace l'icône)" },
        { "type": "text", "id": "title", "label": "Titre", "default": "45 Day Money Back Guarantee" },
        { "type": "text", "id": "text", "label": "Texte", "default": "We're sure you'll love your new pair, if not we'll replace it for free." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hapyco · Guarantee",
      "blocks": [
        { "type": "item", "settings": { "icon": "leaf", "title": "Ethically Sourced Bamboo", "text": "Made with sustainable bamboo, so you can feel good about what you're wearing." } },
        { "type": "item", "settings": { "icon": "shield", "title": "45 Day Money Back Guarantee", "text": "We're sure you'll love your new pair of BoxHero, if not we'll replace it for free." } },
        { "type": "item", "settings": { "icon": "support", "title": "24/7 Support", "text": "We're here for you anytime you need us, no matter what." } },
        { "type": "item", "settings": { "icon": "lock", "title": "SSL Secure Payments", "text": "Shop with confidence — our SSL encryption keeps your information safe." } }
      ]
    }
  ]
}
{% endschema %}
