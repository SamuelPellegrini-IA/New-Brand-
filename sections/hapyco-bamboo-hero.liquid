{%- liquid
  assign img_d = section.settings.image_url
  if section.settings.image != blank
    assign img_d = section.settings.image | image_url: width: 2200
  endif
  assign img_m = section.settings.image_url_mobile
  if section.settings.image_mobile != blank
    assign img_m = section.settings.image_mobile | image_url: width: 1200
  endif
  if img_m == blank
    assign img_m = img_d
  endif
-%}
<section class="hapyco-bh section-{{ section.id }}-wrap"
  style="--bh-text:{{ section.settings.text_color }};--bh-body:{{ section.settings.body_color }};--bh-btn-bg:{{ section.settings.button_bg }};--bh-btn-text:{{ section.settings.button_text_color }};--bh-overlay:{{ section.settings.overlay_opacity | divided_by: 100.0 }};--bh-img-d:url('{{ img_d }}');--bh-img-m:url('{{ img_m }}');--bh-align:{{ section.settings.align }}">
  <div class="hapyco-bh__overlay"></div>
  <div class="hapyco-bh__inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hapyco-bh__eyebrow rte">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hapyco-bh__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="hapyco-bh__body rte">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="hapyco-bh__btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@400;600;800&family=Playfair+Display:wght@500;600;700&display=swap');
  .hapyco-bh {
    position: relative;
    width: 100%;
    background-image: var(--bh-img-d);
    background-size: cover;
    background-position: {{ section.settings.focal_desktop }};
    background-repeat: no-repeat;
    overflow: hidden;
    isolation: isolate;
  }
  .hapyco-bh__overlay {
    position: absolute; inset: 0; z-index: 0;
    background: #000; opacity: var(--bh-overlay);
    pointer-events: none;
  }
  .hapyco-bh__inner {
    position: relative; z-index: 1;
    max-width: 742px;
    margin: 0 auto;
    padding: 77px 20px;
    text-align: var(--bh-align);
    color: var(--bh-text);
    font-family: 'Assistant', -apple-system, sans-serif;
  }
  .hapyco-bh__eyebrow, .hapyco-bh__eyebrow p { margin: 0; }
  .hapyco-bh__eyebrow {
    font-weight: 600; font-size: 25px; line-height: 130%; color: var(--bh-text);
  }
  .hapyco-bh__heading {
    margin: 0; padding: 16px 0 25px;
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 500; font-size: 45px; line-height: 118%; color: var(--bh-text);
  }
  .hapyco-bh__body, .hapyco-bh__body p { margin: 0; }
  .hapyco-bh__body {
    padding-bottom: 46px;
    font-weight: 400; font-size: 20px; line-height: 130%; color: var(--bh-body);
  }
  .hapyco-bh__btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 450px; max-width: 100%; height: 57px; padding: 8px 24px;
    border-radius: 5px;
    background: var(--bh-btn-bg); color: var(--bh-btn-text);
    font-weight: 800; font-size: 19px; line-height: 130%; text-decoration: none;
    transition: opacity .2s ease;
  }
  .hapyco-bh__btn:hover { opacity: .9; }
  @media (max-width: 767px) {
    .hapyco-bh { background-image: var(--bh-img-m); background-position: {{ section.settings.focal_mobile }}; }
    .hapyco-bh__inner { padding: 63px 20px; }
    .hapyco-bh__eyebrow { font-size: 18px; }
    .hapyco-bh__heading { font-size: 35px; padding: 14px 0 20px; }
    .hapyco-bh__body { font-size: 16px; padding-bottom: 41px; }
    .hapyco-bh__btn { width: 269px; font-size: 15px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Hapyco · Bannière héro",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Image de fond" },
    { "type": "image_picker", "id": "image", "label": "Image desktop (upload)" },
    { "type": "text", "id": "image_url", "label": "OU image desktop par URL" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image mobile (upload)" },
    { "type": "text", "id": "image_url_mobile", "label": "OU image mobile par URL" },
    { "type": "select", "id": "focal_desktop", "label": "Cadrage desktop", "default": "center", "options": [ {"value":"center","label":"Centre"},{"value":"top","label":"Haut"},{"value":"bottom","label":"Bas"},{"value":"left","label":"Gauche"},{"value":"right","label":"Droite"} ] },
    { "type": "select", "id": "focal_mobile", "label": "Cadrage mobile", "default": "center", "options": [ {"value":"center","label":"Centre"},{"value":"top","label":"Haut"},{"value":"bottom","label":"Bas"},{"value":"left","label":"Gauche"},{"value":"right","label":"Droite"} ] },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Assombrir l'image", "default": 0 },
    { "type": "header", "content": "Contenu" },
    { "type": "select", "id": "align", "label": "Alignement texte", "default": "center", "options": [ {"value":"left","label":"Gauche"},{"value":"center","label":"Centre"},{"value":"right","label":"Droite"} ] },
    { "type": "richtext", "id": "eyebrow", "label": "Sur-titre", "default": "<p>Innovation in men's essentials</p>" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "BambooFiber Technology" },
    { "type": "richtext", "id": "body", "label": "Texte", "default": "<p>We've all dealt with boxers that bunch up, don't breathe, or fall apart. That's why we created BoxHero Bamboo Boxer Shorts — crafted with cutting-edge BambooFiber Technology. Say goodbye to rolling up, sweating, and uncomfortable fits.</p>" },
    { "type": "header", "content": "Bouton" },
    { "type": "text", "id": "button_label", "label": "Texte bouton", "default": "TRY IT RISK-FREE – TODAY AT 50% OFF!" },
    { "type": "url", "id": "button_link", "label": "Lien bouton" },
    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "text_color", "label": "Titre / sur-titre", "default": "#ffffff" },
    { "type": "color", "id": "body_color", "label": "Texte", "default": "#f7f7f7" },
    { "type": "color", "id": "button_bg", "label": "Fond bouton", "default": "#f7f7f7" },
    { "type": "color", "id": "button_text_color", "label": "Texte bouton", "default": "#00237e" }
  ],
  "presets": [{ "name": "Hapyco · Bannière héro" }]
}
{% endschema %}
