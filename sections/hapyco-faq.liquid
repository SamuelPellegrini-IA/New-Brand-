{%- liquid
  assign items = section.blocks
-%}
<div class="hapyco-faq section-{{ section.id }}-padding" style="--f-bg:{{ section.settings.bg_color }};--f-text:{{ section.settings.text_color }};--f-accent:{{ section.settings.accent_color }};--f-border:{{ section.settings.border_color }}">
  <div class="page-width hapyco-faq__wrap">
    {%- if section.settings.eyebrow != blank -%}<p class="hapyco-faq__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="hapyco-faq__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.subheading != blank -%}<p class="hapyco-faq__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    <div class="hapyco-faq__list">
      {%- for block in items -%}
        <details class="hapyco-faq__item"{% if forloop.first and section.settings.open_first %} open{% endif %} {{ block.shopify_attributes }}>
          <summary class="hapyco-faq__q">
            <span>{{ block.settings.question }}</span>
            <svg class="hapyco-faq__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="hapyco-faq__a rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px; }
  @media (min-width:750px){ .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
  .hapyco-faq { background: var(--f-bg); color: var(--f-text); font-family: Montserrat, -apple-system, sans-serif; }
  .hapyco-faq__wrap { max-width: 760px; }
  .hapyco-faq__eyebrow { text-align: center; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--f-accent); margin: 0 0 6px; font-size: 13px; }
  .hapyco-faq__heading { text-align: center; font-size: clamp(24px,3vw,34px); font-weight: 800; margin: 0 0 8px; }
  .hapyco-faq__sub { text-align: center; opacity: .7; margin: 0 0 28px; }
  .hapyco-faq__item { border-bottom: 1px solid var(--f-border); }
  .hapyco-faq__q { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; list-style: none; padding: 18px 4px; font-size: 16px; font-weight: 700; }
  .hapyco-faq__q::-webkit-details-marker { display: none; }
  .hapyco-faq__chev { width: 20px; height: 20px; flex: 0 0 auto; transition: transform .25s ease; color: var(--f-accent); }
  .hapyco-faq__item[open] .hapyco-faq__chev { transform: rotate(180deg); }
  .hapyco-faq__a { padding: 0 4px 18px; font-size: 15px; line-height: 1.6; opacity: .85; }
{%- endstyle -%}

{% schema %}
{
  "name": "Hapyco · FAQ",
  "tag": "section",
  "class": "section",
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Still have questions?" },
    { "type": "text", "id": "subheading", "label": "Sous-titre", "default": "Check here" },
    { "type": "checkbox", "id": "open_first", "label": "Ouvrir la 1ère question", "default": true },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Texte", "default": "#121212" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#00237e" },
    { "type": "color", "id": "border_color", "label": "Séparateur", "default": "#e7e7e7" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding haut", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bas", "default": 56 }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is bamboo fibre?" },
        { "type": "richtext", "id": "answer", "label": "Réponse", "default": "<p>Bamboo fibre is a natural material appreciated for its soft, breathable and antibacterial properties.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hapyco · FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "What is bamboo fibre?", "answer": "<p>Bamboo fibre is a natural material that's increasingly appreciated for its soft, breathable and antibacterial properties.</p>" } },
        { "type": "qa", "settings": { "question": "Why do dermatologists recommend them?", "answer": "<p>Dermatologists recommend our bamboo fibre boxers because of their softness and their ability to keep skin dry and irritation-free.</p>" } },
        { "type": "qa", "settings": { "question": "How does the 2+3 offer work?", "answer": "<p>Our special offer allows you to buy 2 bamboo fibre boxer shorts and receive 3 free.</p>" } },
        { "type": "qa", "settings": { "question": "Are they suitable for sensitive skin?", "answer": "<p>Yes, bamboo fibre boxers are generally suitable for sensitive skin due to their softness and hypoallergenic properties.</p>" } },
        { "type": "qa", "settings": { "question": "Are they machine-washable?", "answer": "<p>Yes, our bamboo fibre boxers are machine-washable. Please follow the care instructions included.</p>" } }
      ]
    }
  ]
}
{% endschema %}
