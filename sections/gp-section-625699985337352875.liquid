    border-radius: 12px !important;
    padding: 15px 18px !important;
    font-size: 16px !important;
    font-weight: 800 !important;
    line-height: 1.1 !important;
    text-align: center !important;
    box-shadow: 0 8px 22px rgba(0,0,0,0.20) !important;
    display: none !important;
    cursor: pointer !important;
  }

  #hapyco-customily-preview-btn.is-visible {
    display: block !important;
  }

  body {
    padding-bottom: 72px !important;
  }
}
</style>

<script>
(function () {
  if (window.innerWidth > 768) return;

  let savedScrollY = 0;
  let hasStartedPersonalizing = false;

  function saveScroll() {
    savedScrollY = window.scrollY || document.documentElement.scrollTop || 0;
  }

  function restoreScroll() {
    setTimeout(function () {
      window.scrollTo(0, savedScrollY);
    }, 50);

    setTimeout(function () {
      window.scrollTo(0, savedScrollY);
    }, 180);

    setTimeout(function () {
      window.scrollTo(0, savedScrollY);
    }, 500);
  }

  function createStickyButton() {
    if (document.getElementById("hapyco-customily-preview-btn")) return;

    const btn = document.createElement("button");
    btn.id = "hapyco-customily-preview-btn";
    btn.type = "button";
    btn.textContent = "Preview Your Design";

    document.body.appendChild(btn);

    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();

      saveScroll();

      const customilyReviewBtn = findCustomilyReviewButton();

      if (customilyReviewBtn) {
        customilyReviewBtn.click();
        restoreScroll();
      } else {
        console.warn("Customily REVIEW button not found");
      }

      return false;
    });
  }

  function showStickyButton() {
    hasStartedPersonalizing = true;

    const btn = document.getElementById("hapyco-customily-preview-btn");
    if (btn) {
      btn.classList.add("is-visible");
    }
  }

  function findCustomilyReviewButton() {
    const allClickable = Array.from(document.querySelectorAll(
      'button, a, input[type="button"], input[type="submit"], [role="button"]'
    ));

    const possibleTexts = [
      "review",
      "preview",
      "prévisualiser",
      "previsualiser",
      "see preview",
      "view preview"
    ];

    const customilyButtons = allClickable.filter(function (el) {
      if (!el || el.id === "hapyco-customily-preview-btn") return false;

      const text = (
        el.innerText ||
        el.textContent ||
        el.value ||
        el.getAttribute("aria-label") ||
        ""
      ).trim().toLowerCase();

      if (!text) return false;

      const hasPreviewText = possibleTexts.some(function (word) {
        return text.includes(word);
      });

      if (!hasPreviewText) return false;

      const parentHtml = (el.closest("div") ? el.closest("div").outerHTML : "").toLowerCase();
      const fullHtml = el.outerHTML.toLowerCase();

      const looksCustomily =
        parentHtml.includes("customily") ||
        fullHtml.includes("customily") ||
        parentHtml.includes("personal") ||
        fullHtml.includes("personal") ||
        parentHtml.includes("upload") ||
        fullHtml.includes("upload");

      return looksCustomily || hasPreviewText;
    });

    if (customilyButtons.length) {
      return customilyButtons[0];
    }

    return null;
  }

  function isPersonalizationElement(el) {
    if (!el) return false;

    const html = (el.outerHTML || "").toLowerCase();
    const parent = el.closest("div, section, form");
    const parentHtml = parent ? (parent.outerHTML || "").toLowerCase() : "";

    return (
      html.includes("customily") ||
      parentHtml.includes("customily") ||
      html.includes("upload") ||
      parentHtml.includes("upload") ||
      html.includes("personal") ||
      parentHtml.includes("personal") ||
      html.includes("swatch") ||
      parentHtml.includes("swatch") ||
      html.includes("color") ||
      parentHtml.includes("color")
    );
  }

  document.addEventListener("DOMContentLoaded", function () {
    createStickyButton();

    document.addEventListener("click", function (e) {
      const target = e.target;

      if (target && target.id === "hapyco-customily-preview-btn") return;

      if (
        target.matches("input, textarea, select, button, label") ||
        isPersonalizationElement(target)
      ) {
        saveScroll();
        showStickyButton();

        if (hasStartedPersonalizing) {
          restoreScroll();
        }
      }
    }, true);

    document.addEventListener("change", function (e) {
      if (
        e.target.matches("input, textarea, select") ||
        isPersonalizationElement(e.target)
      ) {
        saveScroll();
        showStickyButton();
        restoreScroll();
      }
    }, true);

    document.addEventListener("input", function (e) {
      if (
        e.target.matches("input, textarea, select") ||
        isPersonalizationElement(e.target)
      ) {
        saveScroll();
        showStickyButton();
        restoreScroll();
      }
    }, true);
  });
})();
</script>
